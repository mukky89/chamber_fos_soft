<Application x:Class="VotschVc3.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VotschVc3.App.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:ValueOrDashConverter x:Key="ValueOrDash" />
            <conv:BoolToBrushConverter x:Key="BoolToBrush" />
            <conv:InverseBooleanConverter x:Key="InverseBoolean" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
