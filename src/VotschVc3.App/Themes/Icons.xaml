<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================================================================
         Vector icon library (24×24 path data, Material-style).
         Use as button/label content:

             <StackPanel Orientation="Horizontal">
                 <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Edit}" />
                 <TextBlock Text="Upraviť" Style="{StaticResource IconLabel}" />
             </StackPanel>

         The IconPath fill follows the owning Button's Foreground, so icons
         recolour on hover / disabled exactly like the text label.
         ================================================================== -->

    <!-- Base icon glyph: 16×16, scaled uniformly, coloured from the parent Button. -->
    <Style x:Key="IconPath" TargetType="Path">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
    </Style>

    <!-- Label sitting next to an icon inside a button. -->
    <Style x:Key="IconLabel" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="10,0,0,0" />
    </Style>

