<UserControl x:Class="VotschVc3.App.Views.RecordingViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:VotschVc3.App.Views">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="6,2,6,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="← Domov" Command="{Binding DataContext.GoHomeCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                <StackPanel VerticalAlignment="Center" Margin="6,0,0,0">
                    <TextBlock Text="Prehliadač záznamov" FontSize="17" FontFamily="Segoe UI Semibold" />
                    <TextBlock Text="{Binding FilePath}" Style="{StaticResource Caption}" TextTrimming="CharacterEllipsis" MaxWidth="700" />
                </StackPanel>
            </StackPanel>
            <Button Content="Otvoriť CSV…" Style="{StaticResource AccentButton}" HorizontalAlignment="Right"
                    Command="{Binding OpenCommand}" />
        </Grid>

        <!-- Chart -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <views:ChartView Series="{Binding Series}" EmptyText="Otvor CSV záznam…" />
        </Border>

        <!-- Statistics -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Štatistika" Style="{StaticResource Heading}" />
                <DataGrid ItemsSource="{Binding Stats}" MaxHeight="200" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="34">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Rectangle Width="14" Height="14" RadiusX="3" RadiusY="3" Fill="{Binding Color}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Séria" Width="*" Binding="{Binding Name}" />
                        <DataGridTextColumn Header="Min" Width="110" Binding="{Binding Min}" />
                        <DataGridTextColumn Header="Max" Width="110" Binding="{Binding Max}" />
                        <DataGridTextColumn Header="Priemer" Width="110" Binding="{Binding Mean}" />
                        <DataGridTextColumn Header="Vzoriek" Width="90" Binding="{Binding Count}" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <!-- Status -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="6,10,6,0" Padding="14,8">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" />
        </Border>
    </Grid>
</UserControl>
