<UserControl x:Class="VotschVc3.App.Views.ProfilePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VotschVc3.App.ViewModels"
             xmlns:core="clr-namespace:VotschVc3.Core.Profiles;assembly=VotschVc3.Core">
    <Grid>
        <!-- Closed state: a combo-like button showing the current selection (name + caption). -->
        <ToggleButton x:Name="ToggleBtn" Cursor="Hand" HorizontalContentAlignment="Stretch"
                      Checked="OnToggleChecked">
            <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd" Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="10,6" MinHeight="46">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- Selected profile -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center"
                                        Visibility="{Binding HasSelection, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding SelectedName, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           FontFamily="Segoe UI Semibold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding SelectedCaption, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           Style="{StaticResource Caption}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <!-- Placeholder when nothing is selected -->
                            <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                       Text="{Binding Placeholder, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       Foreground="{StaticResource MutedBrush}"
                                       Visibility="{Binding HasSelection, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                            <Path Grid.Column="1" VerticalAlignment="Center" Margin="8,0,2,0"
                                  Data="M0,0 L9,0 L4.5,5 Z" Fill="{StaticResource MutedBrush}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </ToggleButton.Template>
        </ToggleButton>

        <!-- Open state: search box + grouped tree (customer / sensor → profiles). -->
        <Popup x:Name="Popup" PlacementTarget="{Binding ElementName=ToggleBtn}" Placement="Bottom"
               IsOpen="{Binding IsChecked, ElementName=ToggleBtn}" StaysOpen="False"
               AllowsTransparency="True" PopupAnimation="Fade" Focusable="False"
               MinWidth="{Binding ActualWidth, ElementName=ToggleBtn}" Closed="OnPopupClosed">
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,4,8,8"
                    MaxHeight="400" MinWidth="340">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.5" Color="Black" />
                </Border.Effect>
                <DockPanel>
                    <!-- Search field with icon + placeholder -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBox x:Name="SearchBox" Padding="28,7,8,7" TextChanged="OnSearchChanged"
                                 Background="{StaticResource SurfaceAltBrush}"
                                 ToolTip="Hľadaj podľa názvu, snímača, zákazníka, projektu alebo tagu." />
                        <TextBlock Text="🔍" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12"
                                   Foreground="{StaticResource MutedBrush}" IsHitTestVisible="False" />
                        <TextBlock Text="Hľadať profil…" VerticalAlignment="Center" Margin="30,0,0,0"
                                   Foreground="{StaticResource MutedBrush}" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <TextBlock DockPanel.Dock="Bottom" Style="{StaticResource Caption}" Margin="2,6,2,0"
                               Text="{Binding ResultSummary, RelativeSource={RelativeSource AncestorType=UserControl}}" />

                    <TreeView x:Name="Tree"
                              ItemsSource="{Binding Groups, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              Background="Transparent" BorderThickness="0" MaxHeight="310"
                              SelectedItemChanged="OnTreeSelectedItemChanged"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.Resources>
                            <!-- Group node: customer / sensor header -->
                            <HierarchicalDataTemplate DataType="{x:Type vm:ProfileTreeGroupViewModel}"
                                                      ItemsSource="{Binding Profiles}">
                                <TextBlock Text="{Binding DisplayHeader}" FontFamily="Segoe UI Semibold"
                                           Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" />
                            </HierarchicalDataTemplate>
                            <!-- Profile leaf: name + caption (sensors · project · tags) -->
                            <DataTemplate DataType="{x:Type core:TestProfile}">
                                <StackPanel Margin="0,1" ToolTip="Klik vyberie tento profil.">
                                    <TextBlock Text="{Binding Name}" FontFamily="Segoe UI Semibold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding PickerCaption}" Style="{StaticResource Caption}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </DockPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
