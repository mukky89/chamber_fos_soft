<UserControl x:Class="VotschVc3.App.Views.SikaThermalBathGraphic"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Viewbox Stretch="Uniform">
        <Canvas Width="300" Height="380">

            <!-- ===== Shadow ===== -->
            <Ellipse Canvas.Left="40" Canvas.Top="338" Width="220" Height="26" Fill="#24000000" />

            <!-- ===== Feet ===== -->
            <Rectangle Canvas.Left="62" Canvas.Top="330" Width="14" Height="12" RadiusX="2" RadiusY="2" Fill="#26262A" />
            <Rectangle Canvas.Left="224" Canvas.Top="330" Width="14" Height="12" RadiusX="2" RadiusY="2" Fill="#26262A" />

            <!-- ===== Body (red cabinet) ===== -->
            <Rectangle Canvas.Left="50" Canvas.Top="96" Width="200" Height="240" RadiusX="14" RadiusY="14"
                       Stroke="#8E1420" StrokeThickness="1.5">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#E23A3A" Offset="0" />
                        <GradientStop Color="#D42F35" Offset="0.45" />
                        <GradientStop Color="#B81F28" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <!-- Body highlight -->
            <Rectangle Canvas.Left="58" Canvas.Top="104" Width="8" Height="224" RadiusX="4" RadiusY="4"
                       Fill="#FFFFFF" Opacity="0.16" />

            <!-- ===== Black centre pillar (screen mount + I/O) ===== -->
            <Rectangle Canvas.Left="94" Canvas.Top="96" Width="112" Height="240" Fill="#181818" Opacity="0.94" />

            <!-- ===== Touchscreen (angled control panel) ===== -->
            <Polygon Points="70,140 230,140 224,196 76,196" Stroke="#0C0C0E" StrokeThickness="1.5">
                <Polygon.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#22262E" Offset="0" />
                        <GradientStop Color="#0A0C10" Offset="1" />
                    </LinearGradientBrush>
                </Polygon.Fill>
            </Polygon>
            <!-- Left icon rail -->
            <Rectangle Canvas.Left="76" Canvas.Top="146" Width="20" Height="44" Fill="#B8202A" Opacity="0.9" RadiusX="2" RadiusY="2" />
            <Ellipse Canvas.Left="82" Canvas.Top="151" Width="8" Height="8" Fill="#F3B7BA" />
            <Ellipse Canvas.Left="82" Canvas.Top="163" Width="8" Height="8" Fill="#F3B7BA" Opacity="0.6" />
            <Ellipse Canvas.Left="82" Canvas.Top="175" Width="8" Height="8" Fill="#F3B7BA" Opacity="0.6" />
            <!-- Reading -->
            <TextBlock Canvas.Left="104" Canvas.Top="150" Width="118" TextAlignment="Center"
                       FontFamily="Consolas" FontSize="17" FontWeight="Bold" Foreground="#E9F6FF">
                <Run Text="{Binding TemperatureText, ElementName=Root, Mode=OneWay}" /><Run Text=" °C" />
            </TextBlock>
            <Ellipse x:Name="RunDot" Canvas.Left="212" Canvas.Top="150" Width="6" Height="6" Fill="#4FD6C4" />
            <TextBlock Canvas.Left="104" Canvas.Top="174" Width="118" TextAlignment="Center"
                       Text="{Binding TitleText, ElementName=Root}"
                       FontFamily="Segoe UI Semibold" FontSize="8" Foreground="#8FA0B8" />

            <!-- ===== ext. Ref connector ===== -->
            <Ellipse Canvas.Left="104" Canvas.Top="214" Width="18" Height="18" Stroke="#D8DCE4" StrokeThickness="1.6" Fill="#101012" />
            <TextBlock Canvas.Left="126" Canvas.Top="217" Text="ext. Ref." FontFamily="Segoe UI Semibold" FontSize="8" Foreground="#D8DCE4" />

            <!-- ===== I/O panel (LAN + 2x USB) ===== -->
            <Rectangle Canvas.Left="104" Canvas.Top="252" Width="14" Height="11" RadiusX="1.5" RadiusY="1.5" Stroke="#B7BEC9" StrokeThickness="1" Fill="#0C0C0E" />
            <Rectangle Canvas.Left="126" Canvas.Top="252" Width="11" Height="11" RadiusX="1.5" RadiusY="1.5" Stroke="#B7BEC9" StrokeThickness="1" Fill="#0C0C0E" />
            <Rectangle Canvas.Left="143" Canvas.Top="252" Width="11" Height="11" RadiusX="1.5" RadiusY="1.5" Stroke="#B7BEC9" StrokeThickness="1" Fill="#0C0C0E" />

            <!-- ===== Power switch + inlet ===== -->
            <Rectangle Canvas.Left="140" Canvas.Top="284" Width="20" Height="12" RadiusX="2" RadiusY="2" Fill="#1B1B1D" Stroke="#0A0A0B" StrokeThickness="1" />
            <Rectangle Canvas.Left="134" Canvas.Top="304" Width="32" Height="22" RadiusX="3" RadiusY="3" Fill="#101012" Stroke="#000000" StrokeThickness="1" />

            <!-- ===== Top fan housing (perspective) ===== -->
            <Polygon Points="60,96 100,58 236,58 240,96" Stroke="#0A0A0A" StrokeThickness="1">
                <Polygon.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#3A3A3E" Offset="0" />
                        <GradientStop Color="#1B1B1D" Offset="1" />
                    </LinearGradientBrush>
                </Polygon.Fill>
            </Polygon>
            <!-- Handle -->
            <Rectangle Canvas.Left="128" Canvas.Top="40" Width="60" Height="14" RadiusX="7" RadiusY="7"
                       Fill="#141416" Stroke="#050506" StrokeThickness="1.4" />
            <Rectangle Canvas.Left="118" Canvas.Top="50" Width="12" Height="20" RadiusX="4" RadiusY="4" Fill="#141416" />
            <Rectangle Canvas.Left="186" Canvas.Top="50" Width="12" Height="20" RadiusX="4" RadiusY="4" Fill="#141416" />

            <!-- Grille frame -->
            <Ellipse Canvas.Left="98" Canvas.Top="60" Width="118" Height="46" Fill="#0A0A0B" Stroke="#3E3E42" StrokeThickness="1.5" />

            <!-- Rotating blades (spin while running) -->
            <Canvas x:Name="FanGroup" Canvas.Left="0" Canvas.Top="0">
                <Canvas.RenderTransform>
                    <RotateTransform x:Name="FanRotate" CenterX="157" CenterY="83" />
                </Canvas.RenderTransform>
                <Ellipse Canvas.Left="105" Canvas.Top="78" Width="50" Height="11" Fill="#8A9099" Opacity="0.9" />
                <Ellipse Canvas.Left="105" Canvas.Top="78" Width="50" Height="11" Fill="#8A9099" Opacity="0.9">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="60" CenterX="25" CenterY="5.5" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Canvas.Left="105" Canvas.Top="78" Width="50" Height="11" Fill="#8A9099" Opacity="0.9">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="120" CenterX="25" CenterY="5.5" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Canvas.Left="105" Canvas.Top="78" Width="50" Height="11" Fill="#8A9099" Opacity="0.9">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="180" CenterX="25" CenterY="5.5" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Canvas.Left="105" Canvas.Top="78" Width="50" Height="11" Fill="#8A9099" Opacity="0.9">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="240" CenterX="25" CenterY="5.5" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Canvas.Left="105" Canvas.Top="78" Width="50" Height="11" Fill="#8A9099" Opacity="0.9">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="300" CenterX="25" CenterY="5.5" />
                    </Ellipse.RenderTransform>
                </Ellipse>
            </Canvas>
            <!-- Grille ribs (drawn on top of the blades, like a real fan guard) -->
            <Line X1="102" Y1="83" X2="212" Y2="83" Stroke="#050505" StrokeThickness="1.6" Opacity="0.85" />
            <Line X1="118" Y1="64" X2="150" Y2="102" Stroke="#050505" StrokeThickness="1.4" Opacity="0.7" />
            <Line X1="164" Y1="64" X2="196" Y2="102" Stroke="#050505" StrokeThickness="1.4" Opacity="0.7" />
            <!-- Hub -->
            <Ellipse Canvas.Left="150" Canvas.Top="76" Width="14" Height="14" Fill="#111114" Stroke="#4FD6C4" StrokeThickness="2" />

            <!-- ===== Idle veil ===== -->
            <Rectangle x:Name="IdleVeil" Canvas.Left="50" Canvas.Top="96" Width="200" Height="240"
                       RadiusX="14" RadiusY="14" Fill="#5A0E12" Opacity="0.55"
                       IsHitTestVisible="False" Visibility="Collapsed" />
        </Canvas>
    </Viewbox>
</UserControl>
