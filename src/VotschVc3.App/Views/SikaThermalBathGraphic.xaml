<UserControl x:Class="VotschVc3.App.Views.SikaThermalBathGraphic"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Viewbox Stretch="Uniform">
        <Canvas Width="260" Height="320">

            <!-- ===== Shadow ===== -->
            <Ellipse Canvas.Left="30" Canvas.Top="286" Width="200" Height="22" Fill="#24000000" />

            <!-- ===== Feet ===== -->
            <Rectangle Canvas.Left="46" Canvas.Top="278" Width="12" Height="10" RadiusX="2" RadiusY="2" Fill="#26262A" />
            <Rectangle Canvas.Left="202" Canvas.Top="278" Width="12" Height="10" RadiusX="2" RadiusY="2" Fill="#26262A" />

            <!-- ===== Heating-coil tubes (protrude above the body) ===== -->
            <Path Stroke="#8A2E14" StrokeThickness="9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="{x:Null}">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="86,70" IsClosed="False">
                            <LineSegment Point="86,26" />
                            <ArcSegment Point="112,26" Size="13,13" SweepDirection="Clockwise" />
                            <LineSegment Point="112,70" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
            <Path Stroke="#B5401E" StrokeThickness="6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="{x:Null}">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="86,70" IsClosed="False">
                            <LineSegment Point="86,26" />
                            <ArcSegment Point="112,26" Size="13,13" SweepDirection="Clockwise" />
                            <LineSegment Point="112,70" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
            <Path Stroke="#8A2E14" StrokeThickness="9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="{x:Null}">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="140,70" IsClosed="False">
                            <LineSegment Point="140,32" />
                            <ArcSegment Point="164,32" Size="12,12" SweepDirection="Clockwise" />
                            <LineSegment Point="164,70" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
            <Path Stroke="#B5401E" StrokeThickness="6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="{x:Null}">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="140,70" IsClosed="False">
                            <LineSegment Point="140,32" />
                            <ArcSegment Point="164,32" Size="12,12" SweepDirection="Clockwise" />
                            <LineSegment Point="164,70" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>

            <!-- ===== Body (red cabinet) ===== -->
            <Rectangle Canvas.Left="30" Canvas.Top="70" Width="200" Height="216" RadiusX="20" RadiusY="20"
                       Stroke="#8E1420" StrokeThickness="1.5">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#EA4646" Offset="0" />
                        <GradientStop Color="#D9302F" Offset="0.5" />
                        <GradientStop Color="#B81F28" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <!-- Body highlight -->
            <Rectangle Canvas.Left="40" Canvas.Top="80" Width="8" Height="196" RadiusX="4" RadiusY="4"
                       Fill="#FFFFFF" Opacity="0.16" />

            <!-- ===== Screen ===== -->
            <Rectangle Canvas.Left="54" Canvas.Top="90" Width="152" Height="60" RadiusX="7" RadiusY="7"
                       Stroke="#0C0C0E" StrokeThickness="1.5">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#22262E" Offset="0" />
                        <GradientStop Color="#0A0C10" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <TextBlock Canvas.Left="54" Canvas.Top="98" Width="152" TextAlignment="Center"
                       Text="{Binding TitleText, ElementName=Root}"
                       FontFamily="Segoe UI Semibold" FontSize="9" Foreground="#E6A6A6" />
            <Ellipse x:Name="RunDot" Canvas.Left="188" Canvas.Top="99" Width="6" Height="6" Fill="#4FD6C4" />
            <TextBlock Canvas.Left="54" Canvas.Top="114" Width="152" TextAlignment="Center"
                       FontFamily="Consolas" FontSize="22" FontWeight="Bold" Foreground="#F5FAFF">
                <Run Text="{Binding TemperatureText, ElementName=Root, Mode=OneWay}" /><Run Text=" °C" />
            </TextBlock>

            <!-- ===== Fan (front-facing, spins while running) ===== -->
            <Ellipse Canvas.Left="70" Canvas.Top="176" Width="80" Height="80" Fill="#F2F3F5" Stroke="#C7CBD3" StrokeThickness="2" />
            <Ellipse Canvas.Left="78" Canvas.Top="184" Width="64" Height="64" Fill="#E7E9ED" Stroke="#B9BEC8" StrokeThickness="1.5" />

            <Canvas x:Name="FanGroup">
                <Canvas.RenderTransform>
                    <RotateTransform x:Name="FanRotate" CenterX="110" CenterY="216" />
                </Canvas.RenderTransform>
                <Ellipse Canvas.Left="86" Canvas.Top="211" Width="48" Height="10" Fill="#8A90A0" Opacity="0.85" />
                <Ellipse Canvas.Left="86" Canvas.Top="211" Width="48" Height="10" Fill="#8A90A0" Opacity="0.85">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="60" CenterX="24" CenterY="5" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Canvas.Left="86" Canvas.Top="211" Width="48" Height="10" Fill="#8A90A0" Opacity="0.85">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="120" CenterX="24" CenterY="5" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Canvas.Left="86" Canvas.Top="211" Width="48" Height="10" Fill="#8A90A0" Opacity="0.85">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="180" CenterX="24" CenterY="5" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Canvas.Left="86" Canvas.Top="211" Width="48" Height="10" Fill="#8A90A0" Opacity="0.85">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="240" CenterX="24" CenterY="5" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Canvas.Left="86" Canvas.Top="211" Width="48" Height="10" Fill="#8A90A0" Opacity="0.85">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="300" CenterX="24" CenterY="5" />
                    </Ellipse.RenderTransform>
                </Ellipse>
            </Canvas>

            <!-- Grille ribs on top of the blades -->
            <Line X1="76" Y1="216" X2="144" Y2="216" Stroke="#9AA0AC" StrokeThickness="1.6" Opacity="0.9" />
            <Line X1="83" Y1="192" X2="137" Y2="240" Stroke="#9AA0AC" StrokeThickness="1.4" Opacity="0.75" />
            <Line X1="137" Y1="192" X2="83" Y2="240" Stroke="#9AA0AC" StrokeThickness="1.4" Opacity="0.75" />
            <!-- Hub -->
            <Ellipse Canvas.Left="102" Canvas.Top="208" Width="16" Height="16" Fill="#DADDE2" Stroke="#8B909C" StrokeThickness="1.5" />
            <Ellipse Canvas.Left="107" Canvas.Top="213" Width="6" Height="6" Fill="#C0202A" />

            <!-- ===== Idle veil ===== -->
            <Rectangle x:Name="IdleVeil" Canvas.Left="30" Canvas.Top="70" Width="200" Height="216"
                       RadiusX="20" RadiusY="20" Fill="#5A0E12" Opacity="0.55"
                       IsHitTestVisible="False" Visibility="Collapsed" />
        </Canvas>
    </Viewbox>
</UserControl>
