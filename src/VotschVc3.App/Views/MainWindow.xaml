<Window x:Class="VotschVc3.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VotschVc3.App.ViewModels"
        xmlns:views="clr-namespace:VotschVc3.App.Views"
        Title="Vötsch — Riadenie klimatických komôr"
        Height="820" Width="1240" MinHeight="640" MinWidth="1040"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ShellViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ChamberViewModel}">
            <views:ChamberView />
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="14">
        <ContentControl Content="{Binding CurrentView}" />
    </Grid>
</Window>
