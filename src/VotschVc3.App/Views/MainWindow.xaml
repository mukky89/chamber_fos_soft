<Window x:Class="VotschVc3.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VotschVc3.App.ViewModels"
        Title="Vötsch VC3 — Climate Chamber Control"
        Height="760" Width="1180" MinHeight="600" MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.Resources>
        <Style x:Key="FieldStack" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0" Margin="6,4,6,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Vötsch VC3" FontSize="20" FontFamily="Segoe UI Semibold" />
                <TextBlock Text="Climate Chamber Control" FontSize="20" Margin="8,0,0,0"
                           Foreground="{StaticResource MutedBrush}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Ellipse Width="12" Height="12" VerticalAlignment="Center"
                         Fill="{Binding IsConnected, Converter={StaticResource BoolToBrush}}" />
                <TextBlock Text="{Binding ConnectionState}" Margin="8,0,0,0" />
            </StackPanel>
        </Grid>

        <!-- ===== Tabs ===== -->
        <TabControl Grid.Row="1">

            <!-- ===== Connection & Live ===== -->
            <TabItem Header="Connection &amp; Live">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Connection settings -->
                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Connection (Ethernet / TCP)" Style="{StaticResource Heading}" />

                            <StackPanel Style="{StaticResource FieldStack}">
                                <TextBlock Text="Host / IP address" Style="{StaticResource Label}" />
                                <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="TCP port" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="Chamber address" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="Analog channels" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding AnalogChannelCount, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="Start channel index" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding StartChannelIndex, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Style="{StaticResource FieldStack}">
                                <TextBlock Text="Frame terminator" Style="{StaticResource Label}" />
                                <ComboBox ItemsSource="{Binding TerminatorOptions}"
                                          SelectedItem="{Binding SelectedTerminator}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="Connect" Style="{StaticResource AccentButton}"
                                        Command="{Binding ConnectCommand}" />
                                <Button Content="Disconnect" Style="{StaticResource DangerButton}"
                                        Command="{Binding DisconnectCommand}" />
                            </StackPanel>

                            <Separator Margin="0,14" Background="{StaticResource BorderBrush}" />

                            <CheckBox Content="Live polling" IsChecked="{Binding PollingEnabled}" />
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Interval (s)" Style="{StaticResource Caption}"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox Width="70" Text="{Binding PollIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Content="Read once" Margin="10,0,0,0"
                                        Command="{Binding ReadOnceCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Live values -->
                    <Border Grid.Column="1" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Live values" Style="{StaticResource Heading}" />

                            <UniformGrid Grid.Row="1" Columns="2" VerticalAlignment="Top">
                                <Border Style="{StaticResource Card}" Background="{StaticResource SurfaceAltBrush}">
                                    <StackPanel>
                                        <TextBlock Text="TEMPERATURE" Style="{StaticResource Caption}" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource Metric}"
                                                       Text="{Binding MeasuredTemperature, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0}" />
                                            <TextBlock Text="°C" Margin="6,0,0,8" VerticalAlignment="Bottom"
                                                       Foreground="{StaticResource MutedBrush}" />
                                        </StackPanel>
                                        <TextBlock Style="{StaticResource Caption}">
                                            <Run Text="Set point: " />
                                            <Run Text="{Binding MeasuredTemperatureSetpoint, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0, Mode=OneWay}" />
                                            <Run Text=" °C" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Background="{StaticResource SurfaceAltBrush}">
                                    <StackPanel>
                                        <TextBlock Text="HUMIDITY" Style="{StaticResource Caption}" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource Metric}"
                                                       Text="{Binding MeasuredHumidity, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0}" />
                                            <TextBlock Text="%" Margin="6,0,0,8" VerticalAlignment="Bottom"
                                                       Foreground="{StaticResource MutedBrush}" />
                                        </StackPanel>
                                        <TextBlock Style="{StaticResource Caption}">
                                            <Run Text="Set point: " />
                                            <Run Text="{Binding MeasuredHumiditySetpoint, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0, Mode=OneWay}" />
                                            <Run Text=" %" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <StackPanel Grid.Row="2">
                                <TextBlock Style="{StaticResource Caption}" Margin="6,2">
                                    <Run Text="Last update: " />
                                    <Run Text="{Binding LastUpdate, StringFormat=HH:mm:ss, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Text="Raw frame" Style="{StaticResource Label}" Margin="6,8,0,2" />
                                <Border Style="{StaticResource Card}" Background="{StaticResource BackgroundBrush}" Margin="6,0">
                                    <TextBlock Text="{Binding LastRaw}" FontFamily="Consolas" FontSize="12"
                                               TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== Manual set point ===== -->
            <TabItem Header="Manual set point">
                <Border Style="{StaticResource Card}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="480">
                    <StackPanel>
                        <TextBlock Text="Manual set point" Style="{StaticResource Heading}" />

                        <StackPanel Style="{StaticResource FieldStack}">
                            <TextBlock Text="Temperature (°C)" Style="{StaticResource Label}" />
                            <TextBox Text="{Binding ManualTemperature, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <CheckBox Content="Control humidity" IsChecked="{Binding ControlHumidity}" />
                        <StackPanel Style="{StaticResource FieldStack}"
                                    IsEnabled="{Binding ControlHumidity}">
                            <TextBlock Text="Humidity (% r.h.)" Style="{StaticResource Label}" />
                            <TextBox Text="{Binding ManualHumidity, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Style="{StaticResource FieldStack}">
                            <TextBlock Text="Digital channels (32 bits, advanced)" Style="{StaticResource Label}" />
                            <TextBox Text="{Binding DigitalChannelsText, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas" />
                            <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="The start / 'system on' channel is set automatically on Apply and cleared on Stop, using the start channel index from the Connection tab." />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Apply set point" Style="{StaticResource AccentButton}"
                                    Command="{Binding ApplySetpointCommand}" />
                            <Button Content="Stop chamber" Style="{StaticResource DangerButton}"
                                    Command="{Binding StopChamberCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- ===== Profile ===== -->
            <TabItem Header="Profile (ramps &amp; plateaus)">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Profile name" Style="{StaticResource Label}" />
                                <TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Cycles" Style="{StaticResource Label}" />
                                <TextBox Text="{Binding Cycles, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Write interval (s)" Style="{StaticResource Label}" />
                                <TextBox Text="{Binding ProfileUpdateIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <DataGrid Grid.Column="0"
                                      ItemsSource="{Binding Segments}"
                                      SelectedItem="{Binding SelectedSegment, Mode=TwoWay}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Width="*"
                                                        Binding="{Binding Name}" />
                                    <DataGridTextColumn Header="Target °C" Width="100"
                                                        Binding="{Binding TargetTemperature, StringFormat=0.0}" />
                                    <DataGridTextColumn Header="Target %" Width="100"
                                                        Binding="{Binding TargetHumidity, StringFormat=0.0, TargetNullValue=''}" />
                                    <DataGridTextColumn Header="Duration (min)" Width="120"
                                                        Binding="{Binding DurationMinutes, StringFormat=0.##}" />
                                    <DataGridCheckBoxColumn Header="Ramp" Width="70"
                                                            Binding="{Binding IsRamp, UpdateSourceTrigger=PropertyChanged}" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0" Width="120">
                                <Button Content="Add" Command="{Binding AddSegmentCommand}" Margin="0,0,0,8" />
                                <Button Content="Remove" Command="{Binding RemoveSegmentCommand}" Margin="0,0,0,8" />
                                <Button Content="Move up" Command="{Binding MoveSegmentUpCommand}" Margin="0,0,0,8" />
                                <Button Content="Move down" Command="{Binding MoveSegmentDownCommand}" Margin="0,0,0,8" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="Start profile" Style="{StaticResource AccentButton}"
                                        Command="{Binding StartProfileCommand}" />
                                <Button Content="Stop profile" Style="{StaticResource DangerButton}"
                                        Command="{Binding StopProfileCommand}" />
                            </StackPanel>
                            <ProgressBar Value="{Binding ProfileProgress, Mode=OneWay}" Maximum="100" />
                            <TextBlock Text="{Binding ProfileStatus}" Style="{StaticResource Caption}" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== Recording ===== -->
            <TabItem Header="Recording">
                <Border Style="{StaticResource Card}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="640">
                    <StackPanel>
                        <TextBlock Text="Data recording (CSV)" Style="{StaticResource Heading}" />
                        <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="Every polled reading is appended as a timestamped row. Enable live polling on the Connection tab and choose the sampling interval there." />

                        <TextBlock Text="Output file" Style="{StaticResource Label}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding RecordingPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Content="Browse…" Margin="8,0,0,0"
                                    Command="{Binding BrowseRecordingPathCommand}" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <Button Content="Start recording" Style="{StaticResource AccentButton}"
                                    Command="{Binding StartRecordingCommand}" />
                            <Button Content="Stop recording" Style="{StaticResource DangerButton}"
                                    Command="{Binding StopRecordingCommand}" />
                            <Ellipse Width="11" Height="11" Margin="12,0,6,0" VerticalAlignment="Center"
                                     Fill="{Binding IsRecording, Converter={StaticResource BoolToBrush}}" />
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="Rows: " />
                                <Run Text="{Binding RecordedRows, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- ===== Terminal ===== -->
            <TabItem Header="Raw terminal">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}" Background="{StaticResource BackgroundBrush}">
                        <ListBox x:Name="TerminalList" ItemsSource="{Binding TerminalLines}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Padding" Value="2,1" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"
                                               Foreground="{StaticResource TextBrush}" TextWrapping="NoWrap" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Grid Grid.Row="1" Margin="6,8,6,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding TerminalInput, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"
                                 KeyDown="TerminalInput_KeyDown" />
                        <Button Grid.Column="1" Content="Send" Style="{StaticResource AccentButton}" Margin="8,0,0,0"
                                Command="{Binding SendTerminalCommand}" />
                        <Button Grid.Column="2" Content="Clear" Margin="8,0,0,0"
                                Command="{Binding ClearTerminalCommand}" />
                    </Grid>

                    <TextBlock Grid.Row="2" Style="{StaticResource Caption}" Margin="6,8,6,0" TextWrapping="Wrap"
                               Text="Examples:  $01I  (read values)   ·   $01E 0050.0 0000.0 0000.0 0000.0 0000.0 0000.0 10000000000000000000000000000000  (write set points + digital)   ·   the terminator is added automatically." />
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="6,10,6,0" Padding="14,8">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" />
        </Border>
    </Grid>
</Window>
