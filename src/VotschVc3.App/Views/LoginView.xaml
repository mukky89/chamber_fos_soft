<UserControl x:Class="VotschVc3.App.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:VotschVc3.App.Views">
    <Grid>
        <Border Style="{StaticResource Card}" Width="360" HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="26">
            <StackPanel>
                <views:ChamberGraphic Width="90" Height="120" HorizontalAlignment="Center" />
                <TextBlock Text="Prihlásenie" FontSize="20" FontFamily="Segoe UI Semibold"
                           HorizontalAlignment="Center" Margin="0,10,0,2" />
                <TextBlock Text="Vötsch — Riadenie klimatických komôr" Style="{StaticResource Caption}"
                           HorizontalAlignment="Center" Margin="0,0,0,16" />

                <TextBlock Text="Užívateľ" Style="{StaticResource Label}" />
                <ComboBox ItemsSource="{Binding UserNames}" SelectedItem="{Binding SelectedUserName}" />

                <TextBlock Text="Heslo" Style="{StaticResource Label}" Margin="0,10,0,3" />
                <PasswordBox x:Name="PasswordBox" Padding="8,6" FontSize="13"
                             KeyDown="PasswordBox_KeyDown" />

                <TextBlock Text="{Binding Error}" Foreground="{StaticResource DangerBrush}"
                           Margin="0,8,0,0" TextWrapping="Wrap" />

                <Button Content="Prihlásiť sa" Style="{StaticResource AccentButton}"
                        HorizontalAlignment="Stretch" Margin="0,16,0,0" Click="Login_Click" />

                <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" TextWrapping="Wrap"
                           Text="Predvolené: admin / admin (plný prístup), operator / operator (len čítanie). Heslá zmeň v users.json." />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
