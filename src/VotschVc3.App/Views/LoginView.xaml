<UserControl x:Class="VotschVc3.App.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:VotschVc3.App.Views">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF15172A" Offset="0" />
                <GradientStop Color="#FF0F111B" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="880" Height="520">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <!-- Hero panel -->
            <Border Grid.Column="0" CornerRadius="18,0,0,18" Padding="40,36">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF272A45" Offset="0" />
                        <GradientStop Color="#FF1B1D30" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Border Width="10" Height="10" CornerRadius="5" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="VÖTSCH CONTROL" FontFamily="Segoe UI Semibold" FontSize="13"
                                   Foreground="{StaticResource MutedBrush}" Margin="10,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <views:ChamberGraphic Width="170" Height="220" HorizontalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="Riadenie klimatických komôr" FontSize="26" FontFamily="Segoe UI Light"
                                   Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" />
                        <TextBlock Text="Profily · grafy · alarmy · teplomery ASL F100 · audit · reporty"
                                   Style="{StaticResource Caption}" Margin="0,8,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Login form -->
            <Border Grid.Column="1" CornerRadius="0,18,18,0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="36,40">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Vitaj späť 👋" FontSize="24" FontFamily="Segoe UI Semibold" />
                    <TextBlock Text="Prihlás sa do aplikácie." Style="{StaticResource Caption}" Margin="0,4,0,22" />

                    <TextBlock Text="Užívateľ" Style="{StaticResource Label}" />
                    <ComboBox ItemsSource="{Binding UserNames}" SelectedItem="{Binding SelectedUserName}" />

                    <TextBlock Text="Heslo" Style="{StaticResource Label}" Margin="0,14,0,3" />
                    <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6">
                        <PasswordBox x:Name="PasswordBox" Padding="9,8" FontSize="13" BorderThickness="0"
                                     Background="Transparent" Foreground="{StaticResource TextBrush}"
                                     CaretBrush="{StaticResource TextBrush}"
                                     KeyDown="PasswordBox_KeyDown" />
                    </Border>

                    <TextBlock Text="{Binding Error}" Foreground="{StaticResource DangerBrush}"
                               Margin="0,10,0,0" TextWrapping="Wrap" />

                    <Button Content="Prihlásiť sa" Style="{StaticResource AccentButton}"
                            HorizontalAlignment="Stretch" Margin="0,18,0,0" Padding="14,10" Click="Login_Click" />

                    <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="8" Padding="12,9" Margin="0,18,0,0">
                        <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap"
                                   Text="Predvolené: admin / admin (plný prístup) · operator / operator (len čítanie). Heslá zmeň v Dokumenty/VotschVc3/users.json." />
                    </Border>

                    <DockPanel LastChildFill="False" Margin="0,12,0,0">
                        <TextBlock Text="{Binding DataContext.AppVersion, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue=''}"
                                   Style="{StaticResource Caption}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                        <Button Content="Changelog" Style="{StaticResource GhostButton}" DockPanel.Dock="Right"
                                Command="{Binding DataContext.OpenChangelogCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                    </DockPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
