<Window x:Class="VotschVc3.App.Views.BulkExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hromadný export profilov"
        Height="620" Width="760" MinHeight="440" MinWidth="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        TextOptions.TextFormattingMode="Display" UseLayoutRounding="True">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="2,0,2,10">
            <TextBlock Text="Hromadný export profilov" FontSize="18" FontFamily="Segoe UI Semibold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,2,0,0"
                       Text="Označ profily, ktoré chceš exportovať do jedného JSON súboru (dá sa spätne importovať alebo pribaliť do buildu)." />
        </StackPanel>

        <DockPanel Grid.Row="1" LastChildFill="False" Margin="2,0,2,6">
            <Button DockPanel.Dock="Left" Content="Označiť všetky" Style="{StaticResource GhostButton}"
                    Command="{Binding SelectAllCommand}" />
            <Button DockPanel.Dock="Left" Content="Zrušiť výber" Style="{StaticResource GhostButton}" Margin="6,0,0,0"
                    Command="{Binding SelectNoneCommand}" />
            <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Style="{StaticResource Caption}">
                <Run Text="Označených: " />
                <Run Text="{Binding IncludedCount, Mode=OneWay}" FontFamily="Segoe UI Semibold" />
            </TextBlock>
        </DockPanel>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="6">
            <Grid>
                <TextBlock Text="Knižnica je prázdna." Style="{StaticResource Caption}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding HasItems, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasItems, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="6"
                                        Padding="10,7" Margin="2,3">
                                    <CheckBox IsChecked="{Binding IsIncluded}">
                                        <StackPanel Margin="4,0,0,0">
                                            <TextBlock Text="{Binding Name}" FontFamily="Segoe UI Semibold" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Info}" Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </CheckBox>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="12,8" Margin="0,10,0,0">
            <StackPanel>
                <TextBlock Text="{Binding Status}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                <ProgressBar Height="8" Margin="0,8,0,0" Minimum="0" Maximum="100" Value="{Binding Progress}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Button Content="Zavrieť" Style="{StaticResource GhostButton}" HorizontalAlignment="Left"
                    Padding="16,7" Click="Close_Click" />
            <Button Style="{StaticResource AccentButton}" HorizontalAlignment="Right" Padding="18,7"
                    Command="{Binding ExportCommand}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Export}" />
                    <TextBlock Text="Exportovať označené" Style="{StaticResource IconLabel}" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
