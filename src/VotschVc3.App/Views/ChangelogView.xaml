<UserControl x:Class="VotschVc3.App.Views.ChangelogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="6,2,6,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="← Domov" Command="{Binding DataContext.GoHomeCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                <TextBlock Text="Changelog — história verzií" FontSize="17" FontFamily="Segoe UI Semibold"
                           VerticalAlignment="Center" Margin="10,0,0,0" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Background="{StaticResource BackgroundBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox Text="{Binding Text, Mode=OneWay}" IsReadOnly="True" BorderThickness="0"
                         Background="Transparent" Foreground="{StaticResource TextBrush}"
                         FontFamily="Consolas" FontSize="13" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Disabled" />
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
