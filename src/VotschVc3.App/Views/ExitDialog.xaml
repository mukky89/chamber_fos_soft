<Window x:Class="VotschVc3.App.Views.ExitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ukončiť aplikáciu"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner" MouseLeftButtonDown="Window_MouseLeftButtonDown"
        KeyDown="Window_KeyDown">

    <!-- Soft drop shadow around a rounded, themed card. -->
    <Border Margin="18" CornerRadius="14" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Width="440">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.55" Color="#000000" />
        </Border.Effect>
        <StackPanel Margin="24,22,24,20">
            <StackPanel Orientation="Horizontal">
                <Border Width="42" Height="42" CornerRadius="21" Background="{StaticResource SurfaceAltBrush}"
                        BorderBrush="{StaticResource DangerBrush}" BorderThickness="1.5" VerticalAlignment="Top">
                    <TextBlock Text="⚠" FontSize="20" Foreground="{StaticResource DangerBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="14,0,0,0">
                    <TextBlock Text="Ukončiť aplikáciu?" FontSize="17" FontFamily="Segoe UI Semibold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Margin="0,6,0,0" MaxWidth="320" HorizontalAlignment="Left"
                               Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"
                               Text="Riadenie a monitorovanie zariadení sa zastaví. Ak chcete appku len skryť, môžete ju nechať bežať v oznamovacej oblasti (tray)." />
                </StackPanel>
            </StackPanel>

            <Separator Margin="0,18,0,14" Background="{StaticResource BorderBrush}" />

            <!-- Actions: destructive exit clearly separated from the safe options. -->
            <Grid>
                <Button Content="Zrušiť" Style="{StaticResource GhostButton}" HorizontalAlignment="Left"
                        Padding="16,7" Click="Cancel_Click" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Skryť do tray" Padding="16,7" Margin="0,0,8,0" Click="Tray_Click"
                            ToolTip="Skryje okno, aplikácia beží ďalej v oznamovacej oblasti." />
                    <Button Content="Ukončiť" Style="{StaticResource DangerButton}" Padding="18,7"
                            Click="Exit_Click" />
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</Window>
