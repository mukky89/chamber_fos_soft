<Window x:Class="VotschVc3.App.Views.BulkImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:VotschVc3.App.Views"
        Title="Hromadný import profilov"
        Height="700" Width="960" MinHeight="520" MinWidth="760"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        TextOptions.TextFormattingMode="Display" UseLayoutRounding="True">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="2,0,2,10">
            <TextBlock Text="Hromadný import profilov" FontSize="18" FontFamily="Segoe UI Semibold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,2,0,0"
                       Text="Načítaj viac súborov naraz, premenuj ich a ulož podľa štandardu: každý profil dostane začiatočný nábeh na prvú teplotu a koncový nábeh na izbovú teplotu." />
        </StackPanel>

        <!-- Options -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Predpona názvu (voliteľné)" Style="{StaticResource Label}" />
                        <TextBox Text="{Binding NamePrefix, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Vloží sa pred názov každého profilu (napr. kód projektu)." />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Typ komory" Style="{StaticResource Label}" />
                        <ComboBox ItemsSource="{Binding ChamberKinds}" SelectedItem="{Binding Kind}"
                                  ToolTip="Pre teplotné komory sa vlhkosť z importu zahodí." />
                    </StackPanel>
                </Grid>

                <CheckBox Content="Aplikovať štandard (nábeh na prvú teplotu + koniec na izbovú)"
                          IsChecked="{Binding ApplyStandard}" Margin="0,10,0,4"
                          ToolTip="Každý profil dostane začiatočný nábeh na prvú teplotu a koncový nábeh (a plato) na izbovú teplotu." />

                <Grid Visibility="{Binding ApplyStandard, Converter={StaticResource BoolToVisibility}}" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Izbová teplota (°C)" Style="{StaticResource Label}" />
                        <views:NumericStepper Value="{Binding RoomTemperature, Mode=TwoWay}" Step="1" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Začiatočný nábeh (min)" Style="{StaticResource Label}" />
                        <views:NumericStepper Value="{Binding InitialRampMinutes, Mode=TwoWay}" Step="5" Minimum="0" />
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Koncový nábeh (min)" Style="{StaticResource Label}" />
                        <views:NumericStepper Value="{Binding FinalRampMinutes, Mode=TwoWay}" Step="5" Minimum="0" />
                    </StackPanel>
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Koncové plato (min)" Style="{StaticResource Label}" />
                        <views:NumericStepper Value="{Binding FinalHoldMinutes, Mode=TwoWay}" Step="15" Minimum="0" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <DockPanel Grid.Row="2" LastChildFill="False" Margin="2,10,2,6">
            <Button DockPanel.Dock="Left" Style="{StaticResource AccentButton}" Command="{Binding AddFilesCommand}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Import}" />
                    <TextBlock Text="Pridať súbory…" Style="{StaticResource IconLabel}" />
                </StackPanel>
            </Button>
            <Button DockPanel.Dock="Left" Content="Vyčistiť" Style="{StaticResource GhostButton}" Margin="8,0,0,0"
                    Command="{Binding ClearCommand}" />
            <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Style="{StaticResource Caption}">
                <Run Text="Vybraných: " />
                <Run Text="{Binding IncludedCount, Mode=OneWay}" FontFamily="Segoe UI Semibold" />
            </TextBlock>
        </DockPanel>

        <!-- Items list -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="6">
            <Grid>
                <TextBlock Text="Zatiaľ žiadne súbory. Tlačidlom „Pridať súbory…“ vyber jeden alebo viac profilov."
                           Style="{StaticResource Caption}" TextWrapping="Wrap"
                           HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420" TextAlignment="Center"
                           Visibility="{Binding HasItems, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasItems, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="6"
                                        Padding="10,8" Margin="2,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="1.5*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsIncluded}" VerticalAlignment="Center"
                                                  Margin="0,0,10,0" ToolTip="Zahrnúť do importu" />

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="Segoe UI Semibold" />
                                            <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,3,0,0">
                                                <Run Text="{Binding FileName, Mode=OneWay}" />
                                                <Run Text=" · " />
                                                <Run Text="{Binding FormatDescription, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Text="{Binding Warnings}" Foreground="{StaticResource WarnBrush}"
                                                       Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,2,0,0"
                                                       Visibility="{Binding HasWarnings, Converter={StaticResource BoolToVisibility}}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PreviewText}" Foreground="{StaticResource MutedBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding StatusText}" FontFamily="Segoe UI Semibold"
                                                       Foreground="{StaticResource OkBrush}" TextWrapping="Wrap" Margin="0,3,0,0"
                                                       Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibility}}" />
                                        </StackPanel>

                                        <Button Grid.Column="4" Content="✕" Style="{StaticResource GhostButton}"
                                                Padding="9,3" VerticalAlignment="Center" Margin="8,0,0,0"
                                                Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" ToolTip="Odobrať zo zoznamu" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Status -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Padding="12,8" Margin="0,10,0,0">
            <TextBlock Text="{Binding Status}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="5" Margin="0,12,0,0">
            <Button Content="Zavrieť" Style="{StaticResource GhostButton}" HorizontalAlignment="Left"
                    Padding="16,7" Click="Close_Click" />
            <Button Style="{StaticResource AccentButton}" HorizontalAlignment="Right" Padding="18,7"
                    Command="{Binding ImportAllCommand}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Save}" />
                    <TextBlock Text="Importovať vybrané" Style="{StaticResource IconLabel}" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
