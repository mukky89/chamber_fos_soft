<UserControl x:Class="VotschVc3.App.Views.AuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="6,2,6,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="← Domov" Command="{Binding DataContext.GoHomeCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                <TextBlock Text="Audit trail (história akcií)" FontSize="17" FontFamily="Segoe UI Semibold"
                           VerticalAlignment="Center" Margin="10,0,0,0" />
            </StackPanel>
            <Button Content="Obnoviť" Style="{StaticResource AccentButton}" HorizontalAlignment="Right"
                    Command="{Binding RefreshCommand}" />
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <DataGrid ItemsSource="{Binding Entries}" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Čas" Width="160" Binding="{Binding TimestampText}" />
                    <DataGridTextColumn Header="Užívateľ" Width="120" Binding="{Binding User}" />
                    <DataGridTextColumn Header="Zdroj" Width="200" Binding="{Binding Source}" />
                    <DataGridTextColumn Header="Akcia" Width="160" Binding="{Binding Action}" />
                    <DataGridTextColumn Header="Detail" Width="*" Binding="{Binding Detail}" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
