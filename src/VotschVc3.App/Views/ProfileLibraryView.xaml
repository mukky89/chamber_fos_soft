<UserControl x:Class="VotschVc3.App.Views.ProfileLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:VotschVc3.App.Views">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="6,2,6,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="← Domov" Command="{Binding DataContext.GoHomeCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="Editor profilov (knižnica)" FontSize="17" FontFamily="Segoe UI Semibold" />
                    <TextBlock Text="Tvorba a úprava profilov bez pripojenia ku komore." Style="{StaticResource Caption}" />
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding RefreshHistoryCommand}"
                        ToolTip="Znovu načíta uložené profily zo súboru (automaticky sa obnovia aj pri vstupe sem).">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Refresh}" />
                        <TextBlock Text="Obnoviť" Style="{StaticResource IconLabel}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding NewProfileCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Add}" />
                        <TextBlock Text="Nový" Style="{StaticResource IconLabel}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ImportProfileCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Import}" />
                        <TextBlock Text="Import…" Style="{StaticResource IconLabel}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ExportProfileCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Export}" />
                        <TextBlock Text="Export…" Style="{StaticResource IconLabel}" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="{Binding IsSegmentsExpanded, Converter={StaticResource BoolToGridLength}, ConverterParameter=380}" />
            </Grid.ColumnDefinitions>

            <!-- Editor: the live chart is pinned at the top ("frozen") so you see the
                 profile build up while you edit the segments in the scrolling area below. -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}"
                        Visibility="{Binding IsSegmentsExpanded, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                    <StackPanel>
                        <DockPanel LastChildFill="False" Margin="0,0,0,4">
                            <TextBlock Text="Editor profilu — ťahaj body myšou (teplota)" Style="{StaticResource Label}" DockPanel.Dock="Left" />
                            <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <Run Text="Trvanie: " Foreground="{StaticResource MutedBrush}" />
                                <Run Text="{Binding ProfileDurationText, Mode=OneWay}" FontFamily="Segoe UI Semibold" />
                            </TextBlock>
                        </DockPanel>
                        <TextBlock Text="{Binding ProfileWarnings}" Foreground="{StaticResource DangerBrush}"
                                   FontFamily="Segoe UI Semibold" Margin="0,0,0,4"
                                   Visibility="{Binding HasProfileWarnings, Converter={StaticResource BoolToVisibility}}" />
                        <views:ProfileEditorChart Height="300" Segments="{Binding Segments}" />
                        <views:ChartView Height="120" Margin="0,6,0,0" Unit=" %"
                                         Visibility="{Binding SupportsHumidity, Converter={StaticResource BoolToVisibility}}"
                                         Series="{Binding HumPreview}" />
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                    <StackPanel>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Názov profilu" Style="{StaticResource Label}" />
                                <TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Typ" Style="{StaticResource Label}" />
                                <ComboBox ItemsSource="{Binding ChamberKinds}" SelectedItem="{Binding Kind}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Počet cyklov" Style="{StaticResource Label}" />
                                <TextBox Text="{Binding Cycles, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <DataGrid Grid.Column="0" ItemsSource="{Binding Segments}" SelectedItem="{Binding SelectedSegment, Mode=TwoWay}"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled" MinHeight="160">
                                <DataGrid.Columns>
                                    <DataGridTextColumn EditingElementStyle="{StaticResource DataGridEditTextBox}" Header="Názov" Width="*" Binding="{Binding Name}" />
                                    <DataGridTextColumn EditingElementStyle="{StaticResource DataGridEditTextBox}" Header="Cieľ °C" Width="84" Binding="{Binding TargetTemperature, StringFormat=0.0}" />
                                    <DataGridTextColumn EditingElementStyle="{StaticResource DataGridEditTextBox}" Header="Cieľ %" Width="84" Binding="{Binding TargetHumidity, StringFormat=0.0, TargetNullValue=''}" />
                                    <DataGridTextColumn EditingElementStyle="{StaticResource DataGridEditTextBox}" Header="Trvanie (min)" Width="108" Binding="{Binding DurationMinutes, StringFormat=0.##}" />
                                    <DataGridCheckBoxColumn Header="Rampa" Width="56" Binding="{Binding IsRamp, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridCheckBoxColumn Header="Soak" Width="52" Binding="{Binding GuaranteedSoak, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridTextColumn EditingElementStyle="{StaticResource DataGridEditTextBox}" Header="Tol °C" Width="60" Binding="{Binding SoakTolerance, StringFormat=0.0}" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" Width="130">
                                <Button Content="Pridať na koniec" Command="{Binding AddSegmentCommand}" Margin="0,0,0,6" />
                                <Button Content="Vložiť pred" Command="{Binding AddSegmentBeforeCommand}" Margin="0,0,0,6" />
                                <Button Content="Vložiť za" Command="{Binding AddSegmentAfterCommand}" Margin="0,0,0,6" />
                                <Button Content="Odobrať" Command="{Binding RemoveSegmentCommand}" Margin="0,0,0,6" />
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="↑" Command="{Binding MoveSegmentUpCommand}" Margin="0" />
                                    <Button Grid.Column="2" Content="↓" Command="{Binding MoveSegmentDownCommand}" Margin="0" />
                                </Grid>
                                <Button Content="⤢ Rozbaliť" Style="{StaticResource GhostButton}"
                                        Command="{Binding ToggleSegmentsExpandCommand}" Margin="0,4,0,0" />
                                <Button Content="⛶ Celá obrazovka" Style="{StaticResource GhostButton}"
                                        Click="ToggleMaximize_Click" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- History -->
            <Border Grid.Column="1" Style="{StaticResource Card}"
                    Visibility="{Binding IsSegmentsExpanded, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <TextBlock Text="Uložené profily" Style="{StaticResource Heading}" DockPanel.Dock="Left" />
                        <Button DockPanel.Dock="Right" Content="↻" Style="{StaticResource GhostButton}" Padding="8,1"
                                Command="{Binding RefreshHistoryCommand}" ToolTip="Obnoviť zoznam zo súboru" />
                        <TextBlock Text="klik = načítať" Style="{StaticResource Caption}"
                                   DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,8,0" />
                    </DockPanel>
                    <ListBox Grid.Row="1" ItemsSource="{Binding History}"
                             SelectedItem="{Binding SelectedHistoryProfile, Mode=TwoWay}"
                             Style="{StaticResource ListWithEmptyHint}"
                             Tag="Zatiaľ žiadne uložené profily. Uprav segmenty vľavo a ulož tlačidlom „Uložiť aktuálny“."
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding LoadFromHistoryCommand}" />
                        </ListBox.InputBindings>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Margin" Value="0,2" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="6" Padding="10,7"
                                        ToolTip="Klik načíta profil do editora (teploty aj všetky parametre).">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontFamily="Segoe UI Semibold" TextWrapping="Wrap" />
                                        <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,2,0,0">
                                            <Run Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm', Mode=OneWay}" />
                                            <Run Text=" · " />
                                            <Run Text="{Binding Kind, Mode=OneWay}" />
                                            <Run Text=" · " />
                                            <Run Text="{Binding Segments.Count, Mode=OneWay}" />
                                            <Run Text=" segm." />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <Button Content="Uložiť aktuálny" Style="{StaticResource AccentButton}" Margin="0,0,0,8"
                                HorizontalAlignment="Stretch" Command="{Binding SaveToHistoryCommand}" />
                        <Button Content="Duplikovať (COPY)" Margin="0,0,0,8" HorizontalAlignment="Stretch"
                                Command="{Binding DuplicateProfileCommand}"
                                ToolTip="Vytvorí kópiu vybraného profilu s príponou „COPY“ v názve a načíta ju do editora." />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Načítať" Command="{Binding LoadFromHistoryCommand}" Margin="0" />
                            <Button Grid.Column="2" Content="{Binding DeleteButtonText}" Style="{StaticResource DangerButton}" Margin="0"
                                    Command="{Binding DeleteFromHistoryCommand}"
                                    ToolTip="Zmazanie vyžaduje dva kliknutia – druhý potvrdzuje do 3 sekúnd." />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="6,10,6,0" Padding="14,8">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" />
        </Border>
    </Grid>
</UserControl>
