<Window x:Class="VotschVc3.App.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Potvrdenie"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner" MouseLeftButtonDown="Window_MouseLeftButtonDown"
        KeyDown="Window_KeyDown">

    <Border Margin="18" CornerRadius="14" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Width="440">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.55" Color="#000000" />
        </Border.Effect>
        <StackPanel Margin="24,22,24,20">
            <StackPanel Orientation="Horizontal">
                <Border x:Name="IconBadge" Width="42" Height="42" CornerRadius="21"
                        Background="{StaticResource SurfaceAltBrush}"
                        BorderBrush="{StaticResource DangerBrush}" BorderThickness="1.5" VerticalAlignment="Top">
                    <TextBlock x:Name="IconGlyph" Text="⚠" FontSize="20" Foreground="{StaticResource DangerBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="14,0,0,0">
                    <TextBlock x:Name="TitleText" Text="Potvrdenie" FontSize="17" FontFamily="Segoe UI Semibold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock x:Name="MessageText" Margin="0,6,0,0" MaxWidth="320" HorizontalAlignment="Left"
                               Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>

            <Separator Margin="0,18,0,14" Background="{StaticResource BorderBrush}" />

            <Grid>
                <Button Content="Zrušiť" Style="{StaticResource GhostButton}" HorizontalAlignment="Left"
                        Padding="16,7" Click="Cancel_Click" />
                <Button x:Name="ConfirmButton" Content="Áno" Style="{StaticResource DangerButton}"
                        HorizontalAlignment="Right" Padding="18,7" Click="Confirm_Click" />
            </Grid>
        </StackPanel>
    </Border>
</Window>
