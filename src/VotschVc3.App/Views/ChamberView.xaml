<UserControl x:Class="VotschVc3.App.Views.ChamberView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:VotschVc3.App.Views"
             DataContextChanged="OnDataContextChanged">
    <UserControl.Resources>
        <Style x:Key="FieldStack" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0" Margin="6,2,6,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="← Domov" Command="{Binding DataContext.GoHomeCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                <Button Content="⚡ Rýchly profil" Margin="8,0,0,0"
                        Command="{Binding DataContext.OpenQuickProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        ToolTip="Otvoriť rýchly vytvárač profilov (teplotný sweep)." />
                <Grid Margin="6,0,10,0">
                    <views:ChamberGraphic Width="34" Height="44" IsRunning="{Binding IsActive}"
                                          Visibility="{Binding IsPolEko, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                    <views:PolEkoGraphic Width="38" Height="44" IsRunning="{Binding IsActive}"
                                         TemperatureText="{Binding MeasuredTemperature, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0}"
                                         Visibility="{Binding IsPolEko, Converter={StaticResource BoolToVisibility}}" />
                </Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" FontSize="17" FontFamily="Segoe UI Semibold" />
                    <TextBlock Text="{Binding KindLabel}" Style="{StaticResource Caption}" />
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Border Background="{StaticResource DangerBrush}" CornerRadius="6" Padding="9,3" Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsAlarm, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding AlarmMessage}" Foreground="White" FontFamily="Segoe UI Semibold" />
                </Border>
                <Ellipse Width="12" Height="12" VerticalAlignment="Center"
                         Fill="{Binding IsConnected, Converter={StaticResource BoolToBrush}}" />
                <TextBlock Text="{Binding ConnectionState}" Margin="8,0,0,0" />
            </StackPanel>
        </Grid>

        <!-- ===== Tabs ===== -->
        <TabControl Grid.Row="1">

            <!-- ===== Connection & Live ===== -->
            <TabItem Header="Pripojenie a live">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Pripojenie (Ethernet / TCP)" Style="{StaticResource Heading}" />
                            <StackPanel Style="{StaticResource FieldStack}">
                                <TextBlock Text="Host / IP adresa" Style="{StaticResource Label}" />
                                <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="TCP port" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="Adresa komory" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Vötsch: 2-miestna adresa v rámci ASCII-2. POL-EKO: MODBUS unit ID (zvyčajne 1)." />
                                </StackPanel>
                            </Grid>
                            <!-- ASCII-2 specific settings – meaningless for a MODBUS (POL-EKO) device. -->
                            <StackPanel Visibility="{Binding IsPolEko, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Style="{StaticResource FieldStack}">
                                        <TextBlock Text="Analóg. kanály" Style="{StaticResource Label}" />
                                        <TextBox Text="{Binding AnalogChannelCount, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Style="{StaticResource FieldStack}">
                                        <TextBlock Text="Štart kanál index" Style="{StaticResource Label}" />
                                        <TextBox Text="{Binding StartChannelIndex, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>
                                <StackPanel Style="{StaticResource FieldStack}">
                                    <TextBlock Text="Terminátor rámca" Style="{StaticResource Label}" />
                                    <ComboBox ItemsSource="{Binding TerminatorOptions}" SelectedItem="{Binding SelectedTerminator}" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,8"
                                       Visibility="{Binding IsPolEko, Converter={StaticResource BoolToVisibility}}"
                                       Text="POL-EKO SMART · MODBUS TCP (port 502). Meraná teplota sa číta z input registra; setpoint a štart cez holding registre." />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="Pripojiť" Style="{StaticResource AccentButton}" Command="{Binding ConnectCommand}" />
                                <Button Content="Odpojiť" Style="{StaticResource DangerButton}" Command="{Binding DisconnectCommand}" />
                            </StackPanel>
                            <Separator Margin="0,14" Background="{StaticResource BorderBrush}" />
                            <CheckBox Content="Live polling" IsChecked="{Binding PollingEnabled}" />
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Interval (s)" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox Width="70" Text="{Binding PollIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Content="Načítať raz" Margin="10,0,0,0" Command="{Binding ReadOnceCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Live hodnoty" Style="{StaticResource Heading}" />
                            <Grid Grid.Row="1" VerticalAlignment="Top">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource Card}" Background="{StaticResource SurfaceAltBrush}">
                                    <StackPanel>
                                        <TextBlock Text="TEPLOTA" Style="{StaticResource Caption}" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource Metric}"
                                                       Text="{Binding MeasuredTemperature, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0}" />
                                            <TextBlock Text="°C" Margin="6,0,0,8" VerticalAlignment="Bottom" Foreground="{StaticResource MutedBrush}" />
                                        </StackPanel>
                                        <TextBlock Style="{StaticResource Caption}">
                                            <Run Text="Setpoint: " />
                                            <Run Text="{Binding MeasuredTemperatureSetpoint, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0, Mode=OneWay}" />
                                            <Run Text=" °C" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource Card}" Background="{StaticResource SurfaceAltBrush}"
                                        Visibility="{Binding SupportsHumidity, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel>
                                        <TextBlock Text="VLHKOSŤ" Style="{StaticResource Caption}" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource Metric}"
                                                       Text="{Binding MeasuredHumidity, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0}" />
                                            <TextBlock Text="%" Margin="6,0,0,8" VerticalAlignment="Bottom" Foreground="{StaticResource MutedBrush}" />
                                        </StackPanel>
                                        <TextBlock Style="{StaticResource Caption}">
                                            <Run Text="Setpoint: " />
                                            <Run Text="{Binding MeasuredHumiditySetpoint, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0, Mode=OneWay}" />
                                            <Run Text=" %" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="Priebeh teploty" Style="{StaticResource Label}" Margin="6,0,0,2" />
                                    <views:ChartView Height="180" Margin="4,0,4,8" Unit=" °C"
                                                     EmptyText="Čakám na dáta z pollingu…"
                                                     Series="{Binding LiveTempSeries}" />
                                    <StackPanel Visibility="{Binding SupportsHumidity, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="Priebeh vlhkosti" Style="{StaticResource Label}" Margin="6,4,0,2" />
                                        <views:ChartView Height="160" Margin="4,0,4,8" Unit=" %"
                                                         EmptyText="Čakám na dáta z pollingu…"
                                                         Series="{Binding LiveHumSeries}" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <StackPanel Grid.Row="3">
                                <StackPanel Orientation="Horizontal" Margin="6,0,0,6">
                                    <TextBlock Text="Referenčný teplomer:" Style="{StaticResource Caption}"
                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <ComboBox Width="210" ItemsSource="{Binding AvailableThermometers}"
                                              SelectedItem="{Binding SelectedReferenceThermometer}"
                                              DisplayMemberPath="Display" />
                                    <TextBlock VerticalAlignment="Center" Margin="14,0,0,0"
                                               Visibility="{Binding HasReference, Converter={StaticResource BoolToVisibility}}">
                                        <Run Text="Ref: " Foreground="{StaticResource MutedBrush}" />
                                        <Run Text="{Binding ReferenceTemperature, Converter={StaticResource ValueOrDash}, ConverterParameter=0.000, Mode=OneWay}"
                                             FontFamily="Segoe UI Semibold" />
                                        <Run Text=" °C" Foreground="{StaticResource MutedBrush}" />
                                    </TextBlock>
                                    <TextBlock VerticalAlignment="Center" Margin="14,0,0,0"
                                               Visibility="{Binding HasReference, Converter={StaticResource BoolToVisibility}}">
                                        <Run Text="Δ (komora − ref): " Foreground="{StaticResource MutedBrush}" />
                                        <Run Text="{Binding ReferenceDeviation, Converter={StaticResource ValueOrDash}, ConverterParameter=0.000, Mode=OneWay}"
                                             FontFamily="Segoe UI Semibold" />
                                        <Run Text=" K" Foreground="{StaticResource MutedBrush}" />
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Style="{StaticResource Caption}" Margin="6,2">
                                    <Run Text="Posledná aktualizácia: " />
                                    <Run Text="{Binding LastUpdate, StringFormat=HH:mm:ss, Mode=OneWay}" />
                                    <Run Text="   ·   " />
                                    <Run Text="{Binding LastRaw, Mode=OneWay}" FontFamily="Consolas" />
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== Manual ===== -->
            <TabItem Header="Manuálny setpoint">
                <Border Style="{StaticResource Card}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="480">
                    <StackPanel>
                        <TextBlock Text="Manuálny setpoint" Style="{StaticResource Heading}" />
                        <StackPanel Style="{StaticResource FieldStack}">
                            <TextBlock Text="Teplota (°C)" Style="{StaticResource Label}" />
                            <TextBox Text="{Binding ManualTemperature, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Visibility="{Binding SupportsHumidity, Converter={StaticResource BoolToVisibility}}">
                            <CheckBox Content="Riadiť vlhkosť" IsChecked="{Binding ControlHumidity}" />
                            <StackPanel Style="{StaticResource FieldStack}" IsEnabled="{Binding ControlHumidity}">
                                <TextBlock Text="Vlhkosť (% r.v.)" Style="{StaticResource Label}" />
                                <TextBox Text="{Binding ManualHumidity, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Style="{StaticResource FieldStack}">
                            <TextBlock Text="Digitálne kanály (32 bitov, pokročilé)" Style="{StaticResource Label}" />
                            <TextBox Text="{Binding DigitalChannelsText, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" />
                            <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="Štart kanál sa pri 'Aplikovať' nastaví automaticky a pri 'Stop' vynuluje." />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Aplikovať setpoint" Style="{StaticResource AccentButton}" Command="{Binding ApplySetpointCommand}" />
                            <Button Content="Stop komory" Style="{StaticResource DangerButton}" Command="{Binding StopChamberCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- ===== Profile ===== -->
            <TabItem Header="Profil (rampy a plata)">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="{Binding IsSegmentsExpanded, Converter={StaticResource BoolToGridLength}, ConverterParameter=380}" />
                    </Grid.ColumnDefinitions>

                    <!-- Editor -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                        <StackPanel>

                        <Border Grid.Row="0" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Názov profilu" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Počet cyklov" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding Cycles, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Interval zápisu (s)" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding ProfileUpdateIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <DataGrid x:Name="SegmentsGrid" Grid.Column="0"
                                          ItemsSource="{Binding Segments}"
                                          SelectedItem="{Binding SelectedSegment, Mode=TwoWay}"
                                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                          MinHeight="160">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn EditingElementStyle="{StaticResource DataGridEditTextBox}" Header="Názov" Width="*" Binding="{Binding Name}" />
                                        <DataGridTextColumn EditingElementStyle="{StaticResource DataGridEditTextBox}" Header="Cieľ °C" Width="90" Binding="{Binding TargetTemperature, StringFormat=0.0}" />
                                        <DataGridTextColumn EditingElementStyle="{StaticResource DataGridEditTextBox}" x:Name="HumidityColumn" Header="Cieľ %" Width="90"
                                                            Binding="{Binding TargetHumidity, StringFormat=0.0, TargetNullValue=''}" />
                                        <DataGridTextColumn EditingElementStyle="{StaticResource DataGridEditTextBox}" Header="Trvanie (min)" Width="110" Binding="{Binding DurationMinutes, StringFormat=0.##}" />
                                        <DataGridCheckBoxColumn Header="Rampa" Width="58" Binding="{Binding IsRamp, UpdateSourceTrigger=PropertyChanged}" />
                                        <DataGridCheckBoxColumn Header="Soak" Width="52" Binding="{Binding GuaranteedSoak, UpdateSourceTrigger=PropertyChanged}" />
                                        <DataGridTextColumn EditingElementStyle="{StaticResource DataGridEditTextBox}" Header="Tol °C" Width="64" Binding="{Binding SoakTolerance, StringFormat=0.0}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" Width="130">
                                    <Button Content="Pridať na koniec" Command="{Binding AddSegmentCommand}" Margin="0,0,0,6" />
                                    <Button Content="Vložiť pred" Command="{Binding AddSegmentBeforeCommand}" Margin="0,0,0,6" />
                                    <Button Content="Vložiť za" Command="{Binding AddSegmentAfterCommand}" Margin="0,0,0,6" />
                                    <Button Content="Odobrať" Command="{Binding RemoveSegmentCommand}" Margin="0,0,0,6" />
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="6" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="↑" Command="{Binding MoveSegmentUpCommand}" Margin="0" />
                                        <Button Grid.Column="2" Content="↓" Command="{Binding MoveSegmentDownCommand}" Margin="0" />
                                    </Grid>
                                    <Button Content="⤢ Rozbaliť zoznam" Style="{StaticResource GhostButton}"
                                            Command="{Binding ToggleSegmentsExpandCommand}" Margin="0,4,0,0" />
                                    <Button Content="⛶ Celá obrazovka" Style="{StaticResource GhostButton}"
                                            Click="ToggleMaximize_Click" Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource Card}"
                                Visibility="{Binding IsSegmentsExpanded, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                            <StackPanel>
                                <DockPanel LastChildFill="False" Margin="0,0,0,4">
                                    <TextBlock Text="Editor profilu — ťahaj body myšou (teplota)" Style="{StaticResource Label}" DockPanel.Dock="Left" />
                                    <TextBlock Text="{Binding ProfileWarnings}" Foreground="{StaticResource DangerBrush}"
                                               FontFamily="Segoe UI Semibold" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                               Visibility="{Binding HasProfileWarnings, Converter={StaticResource BoolToVisibility}}" />
                                </DockPanel>
                                <views:ProfileEditorChart Height="160" Segments="{Binding Segments}" />
                                <views:ChartView Height="110" Margin="0,6,0,0" Unit=" %"
                                                 Visibility="{Binding SupportsHumidity, Converter={StaticResource BoolToVisibility}}"
                                                 Series="{Binding PreviewHumSeries}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3" Style="{StaticResource Card}"
                                Visibility="{Binding IsSegmentsExpanded, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <CheckBox Content="Odložený štart" IsChecked="{Binding UseDelayedStart}" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding ScheduledStartDateText, UpdateSourceTrigger=LostFocus}" Width="110" Margin="12,0,0,0"
                                             IsEnabled="{Binding UseDelayedStart}" ToolTip="Dátum dd.MM.yyyy" />
                                    <TextBox Text="{Binding ScheduledStartTime, UpdateSourceTrigger=PropertyChanged}" Width="70" Margin="8,0,0,0"
                                             IsEnabled="{Binding UseDelayedStart}" ToolTip="Čas HH:mm" />
                                </StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Spustiť profil" Style="{StaticResource AccentButton}" Command="{Binding StartProfileCommand}" />
                                        <Button Content="Pozastaviť / pokračovať" Command="{Binding PauseResumeProfileCommand}" />
                                        <Button Content="Zastaviť" Style="{StaticResource DangerButton}" Command="{Binding StopProfileCommand}" />
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Right">
                                        <TextBlock HorizontalAlignment="Right">
                                            <Run Text="Celkové trvanie: " Foreground="{StaticResource MutedBrush}" />
                                            <Run Text="{Binding ProfileDurationText, Mode=OneWay}" FontFamily="Segoe UI Semibold" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding ProfileScheduleText}" Style="{StaticResource Caption}" HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Grid>
                                <ProgressBar Value="{Binding ProfileProgress, Mode=OneWay}" Maximum="100" />
                                <TextBlock Text="{Binding ProfileStatus}" Style="{StaticResource Caption}" Margin="0,8,0,0" />

                                <Separator Margin="0,12,0,8" Background="{StaticResource BorderBrush}" />
                                <DockPanel LastChildFill="False" Margin="0,0,0,6">
                                    <TextBlock Text="Fronta testov" Style="{StaticResource Label}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                        <Button Content="Pridať aktuálny" Command="{Binding AddToQueueCommand}" />
                                        <Button Content="Odobrať" Command="{Binding RemoveFromQueueCommand}" />
                                        <Button Content="Vyčistiť" Command="{Binding ClearQueueCommand}" />
                                        <Button Content="Spustiť frontu" Style="{StaticResource AccentButton}" Command="{Binding StartQueueCommand}" />
                                    </StackPanel>
                                </DockPanel>
                                <ListBox ItemsSource="{Binding Queue}" SelectedItem="{Binding SelectedQueueItem, Mode=TwoWay}"
                                         Style="{StaticResource ListWithEmptyHint}"
                                         Tag="Fronta je prázdna – tlačidlom „Pridať aktuálny“ zaradíš aktuálny profil a testy pobežia za sebou."
                                         MaxHeight="110">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Summary}" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- History -->
                    <Border Grid.Column="1" Style="{StaticResource Card}"
                            Visibility="{Binding IsSegmentsExpanded, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" LastChildFill="False">
                                <TextBlock Text="História profilov" Style="{StaticResource Heading}" DockPanel.Dock="Left" />
                                <TextBlock Text="dvojklik = načítať" Style="{StaticResource Caption}"
                                           DockPanel.Dock="Right" VerticalAlignment="Center" />
                            </DockPanel>
                            <ListBox Grid.Row="1" ItemsSource="{Binding History}"
                                     SelectedItem="{Binding SelectedHistoryProfile, Mode=TwoWay}"
                                     Style="{StaticResource ListWithEmptyHint}"
                                     Tag="Zatiaľ žiadne uložené profily. Vytvor profil v editore alebo Rýchlom vytváraci a ulož ho tlačidlom „Uložiť aktuálny“."
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding LoadFromHistoryCommand}" />
                                </ListBox.InputBindings>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Margin" Value="0,2" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="6" Padding="10,7"
                                                ToolTip="Dvojklik načíta profil do editora (teploty aj všetky parametre).">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontFamily="Segoe UI Semibold"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,2,0,0">
                                                    <Run Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm', Mode=OneWay}" />
                                                    <Run Text=" · " />
                                                    <Run Text="{Binding Cycles, Mode=OneWay}" />
                                                    <Run Text=" cyklov · " />
                                                    <Run Text="{Binding Segments.Count, Mode=OneWay}" />
                                                    <Run Text=" segm." />
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="Import…" Margin="0" Command="{Binding ImportProfileCommand}" />
                                    <Button Grid.Column="2" Content="Export…" Margin="0" Command="{Binding ExportProfileCommand}" />
                                </Grid>
                                <Button Content="Uložiť aktuálny" Style="{StaticResource AccentButton}" Margin="0,0,0,8"
                                        HorizontalAlignment="Stretch" Command="{Binding SaveToHistoryCommand}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="Načítať" Command="{Binding LoadFromHistoryCommand}" Margin="0" />
                                    <Button Grid.Column="2" Content="{Binding DeleteButtonText}" Style="{StaticResource DangerButton}" Margin="0"
                                            Command="{Binding DeleteFromHistoryCommand}"
                                            ToolTip="Zmazanie vyžaduje dva kliknutia – druhý potvrdzuje do 3 sekúnd." />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== Recording ===== -->
            <TabItem Header="Záznam">
                <Border Style="{StaticResource Card}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="640">
                    <StackPanel>
                        <TextBlock Text="Záznam dát (CSV)" Style="{StaticResource Heading}" />
                        <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="Každé odčítané meranie sa zapíše ako riadok s časovou pečiatkou. Frekvenciu určuje interval pollingu v záložke Pripojenie." />
                        <TextBlock Text="Výstupný súbor" Style="{StaticResource Label}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding RecordingPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Content="Prehľadávať…" Margin="8,0,0,0" Command="{Binding BrowseRecordingPathCommand}" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <Button Content="Spustiť záznam" Style="{StaticResource AccentButton}" Command="{Binding StartRecordingCommand}" />
                            <Button Content="Zastaviť záznam" Style="{StaticResource DangerButton}" Command="{Binding StopRecordingCommand}" />
                            <Ellipse Width="11" Height="11" Margin="12,0,6,0" VerticalAlignment="Center"
                                     Fill="{Binding IsRecording, Converter={StaticResource BoolToBrush}}" />
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="Riadkov: " />
                                <Run Text="{Binding RecordedRows, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- ===== Safety ===== -->
            <TabItem Header="Bezpečnosť">
                <Border Style="{StaticResource Card}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="580">
                    <StackPanel>
                        <TextBlock Text="Alarmy a watchdog" Style="{StaticResource Heading}" />
                        <CheckBox Content="Zapnúť alarmy (limity teploty/vlhkosti)" IsChecked="{Binding AlarmsEnabled}" />

                        <WrapPanel Margin="0,8,0,0">
                            <StackPanel Width="130" Margin="0,0,12,8">
                                <TextBlock Text="Teplota min (°C)" Style="{StaticResource Label}" />
                                <TextBox Text="{Binding TempMin, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Width="130" Margin="0,0,12,8">
                                <TextBlock Text="Teplota max (°C)" Style="{StaticResource Label}" />
                                <TextBox Text="{Binding TempMax, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Width="130" Margin="0,0,12,8"
                                        Visibility="{Binding SupportsHumidity, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Vlhkosť min (%)" Style="{StaticResource Label}" />
                                <TextBox Text="{Binding HumMin, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Width="130" Margin="0,0,12,8"
                                        Visibility="{Binding SupportsHumidity, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Vlhkosť max (%)" Style="{StaticResource Label}" />
                                <TextBox Text="{Binding HumMax, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </WrapPanel>

                        <CheckBox Content="Pri alarme / strate spojenia zastaviť bežiaci profil"
                                  IsChecked="{Binding AutoStopOnAlarm}" Margin="0,6,0,0" />
                        <CheckBox Content="Automaticky sa znovu pripájať po výpadku spojenia"
                                  IsChecked="{Binding AutoReconnect}" />

                        <Separator Margin="0,14" Background="{StaticResource BorderBrush}" />

                        <TextBlock Text="Stav" Style="{StaticResource Label}" />
                        <Border CornerRadius="6" Padding="12,9">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAlarm}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding AlarmMessage}" Foreground="White" FontFamily="Segoe UI Semibold" />
                        </Border>

                        <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,10,0,0"
                                   Text="Watchdog: po 3 neúspešných čítaniach sa spojenie považuje za stratené – spustí sa alarm, voliteľne zastavenie profilu, e-mail a auto-reconnect. E-mail sa odošle aj pri každom novom alarme (ak je nastavený na home page)." />
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- ===== Terminal ===== -->
            <TabItem Header="Surový terminál">
                <DockPanel>

                <!-- Set-point diagnostics (Vötsch only) -->
                <Border DockPanel.Dock="Top" Style="{StaticResource Card}"
                        Visibility="{Binding IsPolEko, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                    <StackPanel>
                        <TextBlock Text="Diagnostika nastavenia teploty" Style="{StaticResource Heading}" />
                        <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,8"
                                   Text="Test zapíše skúšobný setpoint a hneď ho prečíta späť, aby zistil, či komora zápis prijala. Rámce (TX/RX) sa zapíšu aj do App logu." />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Test teplota (°C)" Style="{StaticResource Label}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox Width="70" VerticalAlignment="Center"
                                     Text="{Binding DiagTestTemperature, UpdateSourceTrigger=LostFocus}" />
                            <Button Content="▶ Spustiť test zápisu" Style="{StaticResource AccentButton}" Margin="12,0,0,0"
                                    Command="{Binding RunSetpointDiagnosticCommand}" />
                            <Button Content="Prečítať digitálne" Margin="8,0,0,0"
                                    Command="{Binding ReadDigitalCommand}"
                                    ToolTip="Prečíta digitálne kanály a ukáže nastavené bity – takto nájdeš štart kanál (spusti komoru ručne, prečítaj, ktorý bit je 1)." />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Vložiť ukážkový príkaz do terminálu:" Style="{StaticResource Caption}"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <Button Content="Čítať" Command="{Binding InsertReadCommandCommand}" ToolTip="$..I – prečítať aktuálne hodnoty" />
                            <Button Content="Zápis + štart" Command="{Binding InsertWriteCommandCommand}" ToolTip="Zápis test teploty so zapnutým štart kanálom" />
                            <Button Content="Stop" Command="{Binding InsertStopCommandCommand}" ToolTip="Zápis so štart kanálom = OFF" />
                        </StackPanel>
                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="8" Padding="10,8">
                            <TextBlock Text="{Binding DiagResult}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" />
                        </Border>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource Card}" Background="{StaticResource BackgroundBrush}">
                        <ListBox x:Name="TerminalList" ItemsSource="{Binding TerminalLines}"
                                 Style="{StaticResource ListWithEmptyHint}"
                                 Tag="Zatiaľ žiadna komunikácia. Pripoj sa ku komore – každý TX/RX rámec sa zobrazí tu."
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Padding" Value="2,1" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"
                                               Foreground="{StaticResource TextBrush}" TextWrapping="NoWrap" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                    <Grid Grid.Row="1" Margin="6,8,6,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding TerminalInput, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas" KeyDown="TerminalInput_KeyDown" />
                        <Button Grid.Column="1" Content="Odoslať" Style="{StaticResource AccentButton}" Margin="8,0,0,0" Command="{Binding SendTerminalCommand}" />
                        <Button Grid.Column="2" Content="Vyčistiť" Margin="8,0,0,0" Command="{Binding ClearTerminalCommand}" />
                    </Grid>
                    <TextBlock Grid.Row="2" Style="{StaticResource Caption}" Margin="6,8,6,0" TextWrapping="Wrap"
                               Visibility="{Binding IsPolEko, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                               Text="Príklady:  $01I  (čítať)   ·   $01E 0050.0 0000.0 0000.0 0000.0 0000.0 0000.0 10000000000000000000000000000000  (zápis)   ·   terminátor sa dopĺňa automaticky." />
                    <TextBlock Grid.Row="2" Style="{StaticResource Caption}" Margin="6,8,6,0" TextWrapping="Wrap"
                               Visibility="{Binding IsPolEko, Converter={StaticResource BoolToVisibility}}"
                               Text="MODBUS PDU v HEX (funkcia + dáta):  04 0000 0001 = čítať input register 0 (teplota)   ·   03 0001 0001 = čítať holding register 1   ·   odpoveď je HEX ADU." />
                </Grid>
                </DockPanel>
            </TabItem>

            <!-- ===== Nameplate ===== -->
            <TabItem Header="Zariadenie">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource Card}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="560">
                        <StackPanel>
                            <TextBlock Text="Údaje zo štítku zariadenia" Style="{StaticResource Heading}" />
                            <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,10"
                                       Text="Detaily z typového štítku komory (informatívne). Zmeny sa uložia automaticky." />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="Výrobca" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding Manufacturer, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="Typ / Model" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding DeviceModel, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="Sériové číslo" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding SerialNumber, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="Číslo zákazky" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding OrderNumber, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="Rok výroby" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding YearOfConstruction, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="Systém / schéma č." Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding SystemNumber, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>

                                <StackPanel Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="Chladivo 1" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding Refrigerant1, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.Column="2" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="Chladivo 2" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding Refrigerant2, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>

                                <StackPanel Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="Napájanie" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding SupplyVoltage, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="2" Style="{StaticResource FieldStack}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" /><ColumnDefinition Width="10" /><ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Výkon" Style="{StaticResource Label}" />
                                            <TextBox Text="{Binding NominalPower, UpdateSourceTrigger=LostFocus}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Prúd" Style="{StaticResource Label}" />
                                            <TextBox Text="{Binding NominalCurrent, UpdateSourceTrigger=LostFocus}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="5" Grid.Column="0" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="Prvá kalibrácia" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding FirstCalibration, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>
                                <StackPanel Grid.Row="5" Grid.Column="2" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="Ďalšia kalibrácia" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding NextCalibration, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>

                                <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource FieldStack}">
                                    <TextBlock Text="Poznámky" Style="{StaticResource Label}" />
                                    <TextBox Text="{Binding DeviceNotes, UpdateSourceTrigger=LostFocus}"
                                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="46" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="6,10,6,0" Padding="14,8">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" />
        </Border>
    </Grid>
</UserControl>
