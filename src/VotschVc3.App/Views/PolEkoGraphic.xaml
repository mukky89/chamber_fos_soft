<UserControl x:Class="VotschVc3.App.Views.PolEkoGraphic"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Viewbox Stretch="Uniform">
        <Canvas Width="320" Height="400">

            <!-- ===== Shadow ===== -->
            <Ellipse Canvas.Left="44" Canvas.Top="358" Width="240" Height="30" Fill="#24000000" />

            <!-- ===== Top face (perspective) ===== -->
            <Polygon Points="60,52 96,34 288,34 252,52" Stroke="#C4C8D2" StrokeThickness="1">
                <Polygon.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FBFCFD" Offset="0" />
                        <GradientStop Color="#D3D7DF" Offset="1" />
                    </LinearGradientBrush>
                </Polygon.Fill>
            </Polygon>

            <!-- ===== Right side face ===== -->
            <Polygon Points="252,52 288,34 288,332 252,354" Stroke="#AEB3BF" StrokeThickness="1">
                <Polygon.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#B6BBC6" Offset="0" />
                        <GradientStop Color="#9AA0AD" Offset="1" />
                    </LinearGradientBrush>
                </Polygon.Fill>
            </Polygon>
            <!-- Side vents -->
            <Rectangle Canvas.Left="264" Canvas.Top="250" Width="16" Height="4" RadiusX="2" RadiusY="2" Fill="#8A90A0" Opacity="0.7" />
            <Rectangle Canvas.Left="264" Canvas.Top="260" Width="16" Height="4" RadiusX="2" RadiusY="2" Fill="#8A90A0" Opacity="0.7" />
            <Rectangle Canvas.Left="264" Canvas.Top="270" Width="16" Height="4" RadiusX="2" RadiusY="2" Fill="#8A90A0" Opacity="0.7" />
            <Rectangle Canvas.Left="264" Canvas.Top="280" Width="16" Height="4" RadiusX="2" RadiusY="2" Fill="#8A90A0" Opacity="0.7" />

            <!-- ===== Front body ===== -->
            <Rectangle Canvas.Left="60" Canvas.Top="52" Width="192" Height="302" RadiusX="12" RadiusY="12"
                       Stroke="#C0C4CF" StrokeThickness="1.5">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#E9EBEF" Offset="0" />
                        <GradientStop Color="#F6F7F9" Offset="0.18" />
                        <GradientStop Color="#D4D8E0" Offset="0.5" />
                        <GradientStop Color="#ECEEF2" Offset="0.82" />
                        <GradientStop Color="#C9CDD6" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Brushed-steel hint lines -->
            <Line X1="96" Y1="126" X2="96" Y2="346" Stroke="#FFFFFF" StrokeThickness="1" Opacity="0.32" />
            <Line X1="150" Y1="126" X2="150" Y2="346" Stroke="#FFFFFF" StrokeThickness="1" Opacity="0.32" />
            <Line X1="210" Y1="126" X2="210" Y2="346" Stroke="#FFFFFF" StrokeThickness="1" Opacity="0.32" />

            <!-- ===== Control panel ===== -->
            <Rectangle Canvas.Left="72" Canvas.Top="60" Width="168" Height="54" RadiusX="8" RadiusY="8"
                       Stroke="#C6CAD4" StrokeThickness="1">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F4F5F8" Offset="0" />
                        <GradientStop Color="#DCE0E7" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <TextBlock Canvas.Left="80" Canvas.Top="69" Text="POL-EKO" FontFamily="Segoe UI Semibold" FontSize="8" Foreground="#6A7180" />

            <!-- Touchscreen -->
            <Rectangle Canvas.Left="112" Canvas.Top="64" Width="120" Height="46" RadiusX="5" RadiusY="5"
                       Stroke="#2C3547" StrokeThickness="1">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.5,0.35" GradientOrigin="0.5,0.35" RadiusX="0.75" RadiusY="0.75">
                        <GradientStop Color="#2A3550" Offset="0" />
                        <GradientStop Color="#0B0E16" Offset="1" />
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Ellipse Canvas.Left="118" Canvas.Top="70" Width="4.4" Height="4.4" Fill="#8B93A8" />
            <Ellipse x:Name="RunDot" Canvas.Left="221" Canvas.Top="70" Width="5" Height="5" Fill="#4FD6C4" />
            <TextBlock x:Name="TempLabel" Canvas.Left="112" Canvas.Top="80" Width="120" TextAlignment="Center"
                       FontFamily="Consolas" FontSize="18" FontWeight="Bold" Foreground="#E9F6FF">
                <Run Text="{Binding TemperatureText, ElementName=Root, Mode=OneWay}" /><Run Text=" °C" />
            </TextBlock>

            <!-- ===== Door ===== -->
            <Rectangle Canvas.Left="72" Canvas.Top="122" Width="168" Height="216" RadiusX="9" RadiusY="9"
                       Stroke="#C2C6D1" StrokeThickness="1.5">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#DFE2E9" Offset="0" />
                        <GradientStop Color="#EEF0F4" Offset="0.5" />
                        <GradientStop Color="#CFD3DC" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Rectangle Canvas.Left="80" Canvas.Top="130" Width="152" Height="200" RadiusX="6" RadiusY="6"
                       Stroke="#FFFFFF" StrokeThickness="1" Opacity="0.5" />

            <!-- Model label on the door -->
            <TextBlock Canvas.Left="80" Canvas.Top="318" Text="{Binding TitleText, ElementName=Root}"
                       FontFamily="Segoe UI Semibold" FontSize="10" Foreground="#8A90A6" />

            <!-- Handle -->
            <Ellipse Canvas.Left="89" Canvas.Top="225" Width="14" Height="14" Fill="#2A2D33" Stroke="#1A1C20" StrokeThickness="1" />
            <Rectangle Canvas.Left="96" Canvas.Top="226" Width="58" Height="12" RadiusX="6" RadiusY="6" Fill="#26282E" Stroke="#17181C" StrokeThickness="1" />
            <Ellipse Canvas.Left="93.6" Canvas.Top="229.6" Width="4.8" Height="4.8" Fill="#4B4F57" />

            <!-- Feet -->
            <Rectangle Canvas.Left="70" Canvas.Top="354" Width="12" Height="14" RadiusX="2" RadiusY="2" Fill="#3A3D48" />
            <Rectangle Canvas.Left="230" Canvas.Top="354" Width="12" Height="14" RadiusX="2" RadiusY="2" Fill="#3A3D48" />
            <Rectangle Canvas.Left="256" Canvas.Top="352" Width="10" Height="12" RadiusX="2" RadiusY="2" Fill="#31343D" />

            <!-- ===== Idle veil ===== -->
            <Rectangle x:Name="IdleVeil" Canvas.Left="60" Canvas.Top="52" Width="192" Height="302"
                       RadiusX="12" RadiusY="12" Fill="#B4BAC6" Opacity="0.55"
                       IsHitTestVisible="False" Visibility="Collapsed" />
        </Canvas>
    </Viewbox>
</UserControl>
