<Window x:Class="VotschVc3.App.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Heslo"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner" MouseLeftButtonDown="Window_MouseLeftButtonDown"
        KeyDown="Window_KeyDown">

    <Border Margin="18" CornerRadius="14" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Width="420">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.55" Color="#000000" />
        </Border.Effect>
        <StackPanel Margin="24,22,24,20">
            <StackPanel Orientation="Horizontal">
                <Border Width="42" Height="42" CornerRadius="21" Background="{StaticResource SurfaceAltBrush}"
                        BorderBrush="{StaticResource DangerBrush}" BorderThickness="1.5" VerticalAlignment="Top">
                    <TextBlock Text="🔒" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="14,0,0,0">
                    <TextBlock x:Name="TitleText" Text="Potvrď heslom" FontSize="17" FontFamily="Segoe UI Semibold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock x:Name="MessageText" Margin="0,6,0,0" MaxWidth="320" HorizontalAlignment="Left"
                               Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Heslo admina" Style="{StaticResource Label}" Margin="0,16,0,3" />
            <PasswordBox x:Name="PasswordInput" Height="32" FontSize="13" Padding="8,6"
                         Background="{StaticResource SurfaceAltBrush}" Foreground="{StaticResource TextBrush}"
                         BorderBrush="{StaticResource BorderBrush}" CaretBrush="White" />
            <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" FontSize="12"
                       Margin="0,6,0,0" Visibility="Collapsed" />

            <Separator Margin="0,16,0,14" Background="{StaticResource BorderBrush}" />

            <Grid>
                <Button Content="Zrušiť" Style="{StaticResource GhostButton}" HorizontalAlignment="Left"
                        Padding="16,7" Click="Cancel_Click" />
                <Button x:Name="ConfirmButton" Content="Potvrdiť" Style="{StaticResource DangerButton}"
                        HorizontalAlignment="Right" Padding="18,7" Click="Confirm_Click" />
            </Grid>
        </StackPanel>
    </Border>
</Window>
