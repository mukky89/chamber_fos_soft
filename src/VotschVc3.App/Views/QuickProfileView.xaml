<UserControl x:Class="VotschVc3.App.Views.QuickProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:VotschVc3.App.Views">
    <UserControl.Resources>
        <Style x:Key="QpField" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="6,2,6,8">
            <Button Content="← Domov"
                    Command="{Binding DataContext.GoHomeCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
            <TextBlock Text="Rýchly vytvárač profilov" FontSize="17" FontFamily="Segoe UI Semibold"
                       VerticalAlignment="Center" Margin="10,0,0,0" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ===== Vstupy ===== -->
            <Border Grid.Column="0" Style="{StaticResource Card}" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Parametre sweepu" Style="{StaticResource Heading}" />

                    <StackPanel Style="{StaticResource QpField}">
                        <TextBlock Text="Predpona názvu (voliteľné)" Style="{StaticResource Label}" />
                        <TextBox Text="{Binding NamePrefix, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Napr. kód projektu alebo vzorky – vloží sa pred automaticky generovaný názov." />
                    </StackPanel>

                    <StackPanel Style="{StaticResource QpField}">
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="Názov profilu" Style="{StaticResource Label}" DockPanel.Dock="Left" />
                            <Button DockPanel.Dock="Right" Content="Automaticky" Style="{StaticResource GhostButton}"
                                    Padding="8,1" Command="{Binding ResetNameCommand}"
                                    ToolTip="Znovu vygenerovať názov z parametrov sweepu." />
                        </DockPanel>
                        <TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{Binding NameModeText}" Style="{StaticResource Caption}"
                                   TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Style="{StaticResource QpField}">
                            <TextBlock Text="Od (°C)" Style="{StaticResource Label}" />
                            <views:NumericStepper Value="{Binding LowTemperature, Mode=TwoWay}" Step="5" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Style="{StaticResource QpField}">
                            <TextBlock Text="Do (°C)" Style="{StaticResource Label}" />
                            <views:NumericStepper Value="{Binding HighTemperature, Mode=TwoWay}" Step="5" />
                        </StackPanel>
                    </Grid>

                    <!-- Two ways to choose the intermediate temperatures: a fixed count of
                         steps, or a requested °C step between the endpoints (then generate). -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <RadioButton Content="Počet krokov" IsChecked="{Binding UseStepCount, Mode=OneWay}"
                                     Click="UseStepCount_Click" VerticalAlignment="Center"
                                     ToolTip="Zadáš, koľko teplôt má byť medzi krajnými bodmi." />
                        <RadioButton Content="Krok teploty (°C)" IsChecked="{Binding UseTemperatureStep, Mode=TwoWay}"
                                     Margin="16,0,0,0" VerticalAlignment="Center"
                                     ToolTip="Zadáš požadovaný rozdiel medzi susednými teplotami – počet krokov sa dopočíta." />
                    </StackPanel>

                    <StackPanel Style="{StaticResource QpField}"
                                Visibility="{Binding UseStepCount, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Počet teplôt medzi krajnými (medzikroky)" Style="{StaticResource Label}" />
                        <views:NumericStepper Value="{Binding IntermediateSteps, Mode=TwoWay}" Step="1" Minimum="0" Maximum="50" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource QpField}"
                                Visibility="{Binding UseTemperatureStep, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Krok teploty medzi min a max (°C)" Style="{StaticResource Label}" />
                        <views:NumericStepper Value="{Binding TemperatureStep, Mode=TwoWay}" Step="1" Minimum="0.1" Maximum="200" />
                        <TextBlock Text="Počet krokov sa dopočíta z rozsahu a vygeneruje sa." Style="{StaticResource Caption}" Margin="0,2,0,0" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Style="{StaticResource QpField}">
                            <TextBlock Text="Dĺžka plata (min)" Style="{StaticResource Label}" />
                            <views:NumericStepper Value="{Binding PlateauMinutes, Mode=TwoWay}" Step="5" Minimum="0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Style="{StaticResource QpField}">
                            <TextBlock Text="Dĺžka nábehu (min)" Style="{StaticResource Label}" />
                            <views:NumericStepper Value="{Binding RampMinutes, Mode=TwoWay}" Step="5" Minimum="0" />
                        </StackPanel>
                    </Grid>

                    <CheckBox Content="Aj zostupná časť (späť dole)" IsChecked="{Binding IncludeDescending}"
                              Margin="0,2,0,6" />
                    <CheckBox Content="Dvojitý vrchol (dva najvyššie body)" IsChecked="{Binding DoublePeak}"
                              Margin="0,0,0,6"
                              ToolTip="Na vrchole vytvorí dva najvyššie body a medzi nimi plato o pár °C nižšie, aby prebehla zmena teploty." />
                    <StackPanel Style="{StaticResource QpField}"
                                Visibility="{Binding DoublePeak, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Pokles medzi vrcholmi (°C)" Style="{StaticResource Label}" />
                        <views:NumericStepper Value="{Binding PeakDipCelsius, Mode=TwoWay}" Step="1" Minimum="0" />
                    </StackPanel>

                    <CheckBox Content="Nábeh z aktuálnej teploty" IsChecked="{Binding StartFromCurrent}"
                              Margin="0,0,0,6"
                              ToolTip="Na začiatku pridá rampu z aktuálnej teploty komory na prvú nastavenú teplotu, aby profil neskočil rovno na prvý setpoint." />
                    <Grid Visibility="{Binding StartFromCurrent, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Style="{StaticResource QpField}">
                            <TextBlock Text="Z teploty (°C)" Style="{StaticResource Label}" />
                            <views:NumericStepper Value="{Binding StartTemperature, Mode=TwoWay}" Step="1" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Style="{StaticResource QpField}">
                            <TextBlock Text="Dĺžka nábehu (min)" Style="{StaticResource Label}" />
                            <views:NumericStepper Value="{Binding StartRampMinutes, Mode=TwoWay}" Step="5" Minimum="0" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Optimalizácia" Style="{StaticResource Heading}" Margin="0,4,0,4" />
                    <StackPanel Style="{StaticResource QpField}">
                        <TextBlock Text="Skrátiť celkový čas o (hodín)" Style="{StaticResource Label}" />
                        <views:NumericStepper Value="{Binding ShortenByHours, Mode=TwoWay}" Step="0.5" Minimum="0" />
                        <TextBlock Text="Rovnomerne skráti všetky plata." Style="{StaticResource Caption}" Margin="0,2,0,0" />
                    </StackPanel>

                    <!-- Primary actions on one row (Save = accent, Edit alongside). -->
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Uložiť do knižnice" Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Stretch" Command="{Binding SaveToLibraryCommand}"
                                ToolTip="Uloží (alebo aktualizuje podľa názvu) profil do zdieľanej knižnice." />
                        <Button Grid.Column="2" Content="✎ Editovať profil" HorizontalAlignment="Stretch"
                                Command="{Binding EditInEditorCommand}"
                                ToolTip="Uloží profil a otvorí ho v Editore profilov na ďalšie úpravy segmentov." />
                    </Grid>

                    <Separator Margin="0,10,0,8" Background="{StaticResource BorderBrush}" />

                    <!-- Secondary + destructive, clearly separated. -->
                    <Grid>
                        <Button HorizontalAlignment="Left" Content="↺ Nový / začať odznova"
                                Style="{StaticResource GhostButton}" Command="{Binding NewCommand}"
                                ToolTip="Vynuluje všetky parametre na predvolené hodnoty." />
                        <Button HorizontalAlignment="Right" Content="Vymazať z knižnice"
                                Style="{StaticResource DangerButton}" Command="{Binding DeleteFromLibraryCommand}"
                                ToolTip="Vymaže z knižnice profil s aktuálnym názvom (s potvrdením)." />
                    </Grid>

                    <!-- Prominent confirmation after a successful save. -->
                    <Border Margin="0,4,0,0" CornerRadius="8" Padding="10,8"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource OkBrush}" BorderThickness="1"
                            Visibility="{Binding IsSaveSuccess, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding Status}" Foreground="{StaticResource OkBrush}"
                                   FontFamily="Segoe UI Semibold" TextWrapping="Wrap" />
                    </Border>
                    <TextBlock Text="{Binding Status}" Style="{StaticResource Caption}"
                               TextWrapping="Wrap" Margin="0,8,0,0"
                               Visibility="{Binding IsSaveSuccess, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                </StackPanel>
            </Border>

            <!-- ===== Náhľad + výpočty ===== -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="12,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="Náhľad profilu" Style="{StaticResource Heading}" />
                        <TextBlock Text="{Binding Summary}" Style="{StaticResource Caption}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" />
                    </StackPanel>

                    <views:ChartView Grid.Row="1" Series="{Binding TempPreview}" Unit=" °C"
                                     EmptyText="Zadaj parametre" MinHeight="240" Margin="0,8,0,8" />

                    <WrapPanel Grid.Row="2">
                        <StackPanel Margin="0,0,28,0">
                            <TextBlock Text="Segmentov" Style="{StaticResource Caption}" />
                            <TextBlock Text="{Binding SegmentCount}" FontSize="20" FontFamily="Segoe UI Semibold" />
                        </StackPanel>
                        <StackPanel Margin="0,0,28,0">
                            <TextBlock Text="Nábeh" Style="{StaticResource Caption}" />
                            <TextBlock Text="{Binding RampRateText}" FontSize="16" FontFamily="Segoe UI Semibold" />
                        </StackPanel>
                        <StackPanel Margin="0,0,28,0">
                            <TextBlock Text="Plato po optimalizácii" Style="{StaticResource Caption}" />
                            <TextBlock Text="{Binding EffectivePlateauText}" FontSize="16" FontFamily="Segoe UI Semibold" />
                        </StackPanel>
                        <StackPanel Margin="0,0,28,0">
                            <TextBlock Text="Celkový čas (základ)" Style="{StaticResource Caption}" />
                            <TextBlock Text="{Binding BaseTotalText}" FontSize="16" FontFamily="Segoe UI Semibold" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Celkový čas (optimalizovaný)" Style="{StaticResource Caption}" />
                            <TextBlock Text="{Binding OptimizedTotalText}" FontSize="20" FontFamily="Segoe UI Semibold" />
                        </StackPanel>
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
