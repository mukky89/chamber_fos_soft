<Window x:Class="VotschVc3.App.Views.ChartZoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:VotschVc3.App.Views"
        Title="Graf"
        WindowStyle="None" ResizeMode="NoResize" WindowState="Maximized"
        Background="{StaticResource BackgroundBrush}" ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Grid Margin="24,16,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Padding="14,6" FontSize="14"
                    Content="✕ Zavrieť" ToolTip="Zavrieť zväčšený graf (Esc)" Click="Close_Click" />
            <TextBlock DockPanel.Dock="Right" Text="Esc = zavrieť" Style="{StaticResource Caption}"
                       VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBlock x:Name="TitleText" Style="{StaticResource Heading}" VerticalAlignment="Center" Text="Graf" />
        </DockPanel>

        <views:ChartView x:Name="Chart" Grid.Row="1" AllowZoom="False" />
    </Grid>
</Window>
