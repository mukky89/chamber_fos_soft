<UserControl x:Class="VotschVc3.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:VotschVc3.App.Views">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
        <StackPanel>

        <Grid Margin="6,4,6,12">
            <StackPanel>
                <TextBlock Text="Vyber komoru" FontSize="22" FontFamily="Segoe UI Semibold" />
                <TextBlock Text="Obe komory môžu byť pripojené a bežať súčasne." Style="{StaticResource Caption}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                <Border HorizontalAlignment="Right"
                        Background="{StaticResource SurfaceAltBrush}" CornerRadius="6" Padding="9,4">
                    <TextBlock Text="{Binding AppVersion}" Style="{StaticResource Caption}"
                               ToolTip="Verzia aplikácie — pozri CHANGELOG.md" />
                </Border>
                <Button Content="Editor profilov →" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Right" Margin="0,6,0,0"
                        Command="{Binding OpenProfileLibraryCommand}" />
                <Button Content="Teplomery ASL F100 →" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Right" Margin="0,2,0,0"
                        Command="{Binding OpenThermometersCommand}" />
                <Button Content="Prehliadač záznamov →" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Right" Margin="0,2,0,0"
                        Command="{Binding OpenRecordingViewerCommand}" />
                <Button Content="Audit trail →" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Right" Margin="0,2,0,0"
                        Command="{Binding OpenAuditCommand}" />
                <Button Content="App log →" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Right" Margin="0,2,0,0"
                        Command="{Binding OpenAppLogCommand}" />
                <Button Content="Changelog →" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Right" Margin="0,2,0,0"
                        Command="{Binding OpenChangelogCommand}" />
                <Button Content="Administrácia →" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Right" Margin="0,2,0,0"
                        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"
                        Command="{Binding OpenAdminCommand}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                    <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="6" Padding="9,4" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource Caption}">
                            <Run Text="{Binding CurrentUserName, Mode=OneWay}" FontFamily="Segoe UI Semibold" />
                            <Run Text=" · " />
                            <Run Text="{Binding CurrentRoleLabel, Mode=OneWay}" />
                        </TextBlock>
                    </Border>
                    <Button Content="Odhlásiť" Style="{StaticResource GhostButton}" Margin="6,0,0,0"
                            Command="{Binding LogoutCommand}" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <ItemsControl ItemsSource="{Binding Chambers}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Width="470">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <views:ChamberGraphic Grid.Column="0" Width="150" Height="210"
                                                  VerticalAlignment="Top"
                                                  TitleText="{Binding KindLabel}" />

                            <StackPanel Grid.Column="1" Margin="14,2,0,0">
                                <TextBlock Text="{Binding Name}" FontFamily="Segoe UI Semibold" FontSize="16"
                                           TextWrapping="Wrap" />

                                <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="6"
                                        Padding="8,3" HorizontalAlignment="Left" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding KindLabel}" Style="{StaticResource Caption}" />
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Ellipse Width="11" Height="11" VerticalAlignment="Center"
                                             Fill="{Binding IsConnected, Converter={StaticResource BoolToBrush}}" />
                                    <TextBlock Text="{Binding ConnectionState}" Margin="8,0,0,0" Style="{StaticResource Caption}" />
                                    <Border Background="{StaticResource DangerBrush}" CornerRadius="6" Padding="7,2" Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsAlarm, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="ALARM" Foreground="White" FontFamily="Segoe UI Semibold" FontSize="11" />
                                    </Border>
                                </StackPanel>

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="IP adresa" Style="{StaticResource Label}" />
                                        <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Width="80">
                                        <TextBlock Text="Port" Style="{StaticResource Label}" />
                                        <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="Teplota" Style="{StaticResource Caption}" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontSize="26" FontFamily="Segoe UI Light"
                                                       Text="{Binding MeasuredTemperature, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0}" />
                                            <TextBlock Text="°C" VerticalAlignment="Bottom" Margin="4,0,0,4"
                                                       Foreground="{StaticResource MutedBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Visibility="{Binding SupportsHumidity, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="Vlhkosť" Style="{StaticResource Caption}" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontSize="26" FontFamily="Segoe UI Light"
                                                       Text="{Binding MeasuredHumidity, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0}" />
                                            <TextBlock Text="%" VerticalAlignment="Bottom" Margin="4,0,0,4"
                                                       Foreground="{StaticResource MutedBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Margin="0,10,0,0"
                                            Visibility="{Binding IsProfileRunning, Converter={StaticResource BoolToVisibility}}">
                                    <ProgressBar Value="{Binding ProfileProgress, Mode=OneWay}" Maximum="100" Height="6" />
                                    <TextBlock Text="{Binding ProfileStatus}" Style="{StaticResource Caption}"
                                               Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                    <Button Content="Pripojiť" Style="{StaticResource AccentButton}"
                                            Command="{Binding ConnectCommand}" />
                                    <Button Content="Odpojiť" Command="{Binding DisconnectCommand}" />
                                </StackPanel>

                                <Button Content="Nastaviť / ovládať →" Style="{StaticResource GhostButton}"
                                        Margin="0,10,0,0" HorizontalAlignment="Left"
                                        Command="{Binding DataContext.OpenChamberCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>

                            <Button Grid.ColumnSpan="2" Content="✕" Style="{StaticResource GhostButton}"
                                    HorizontalAlignment="Right" VerticalAlignment="Top" Padding="8,2" Margin="0"
                                    ToolTip="Odobrať komoru"
                                    Visibility="{Binding DataContext.IsAdmin,
                                              RelativeSource={RelativeSource AncestorType=Window},
                                              Converter={StaticResource BoolToVisibility}}"
                                    Command="{Binding DataContext.RemoveChamberCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
