<UserControl x:Class="VotschVc3.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:VotschVc3.App.Views">
    <UserControl.Resources>
        <Style x:Key="MiniField" TargetType="StackPanel">
            <Setter Property="Width" Value="150" />
            <Setter Property="Margin" Value="0,0,12,8" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
        <StackPanel>

        <Grid Margin="6,4,6,12">
            <StackPanel>
                <TextBlock Text="Vyber komoru" FontSize="22" FontFamily="Segoe UI Semibold" />
                <TextBlock Text="Obe komory môžu byť pripojené a bežať súčasne." Style="{StaticResource Caption}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                <Border HorizontalAlignment="Right"
                        Background="{StaticResource SurfaceAltBrush}" CornerRadius="6" Padding="9,4">
                    <TextBlock Text="{Binding AppVersion}" Style="{StaticResource Caption}"
                               ToolTip="Verzia aplikácie — pozri CHANGELOG.md" />
                </Border>
                <Button Content="Editor profilov →" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Right" Margin="0,6,0,0"
                        Command="{Binding OpenProfileLibraryCommand}" />
                <Button Content="Teplomery ASL F100 →" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Right" Margin="0,2,0,0"
                        Command="{Binding OpenThermometersCommand}" />
                <Button Content="Prehliadač záznamov →" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Right" Margin="0,2,0,0"
                        Command="{Binding OpenRecordingViewerCommand}" />
                <Button Content="Audit trail →" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Right" Margin="0,2,0,0"
                        Command="{Binding OpenAuditCommand}" />
                <Button Content="App log →" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Right" Margin="0,2,0,0"
                        Command="{Binding OpenAppLogCommand}" />
                <Button Content="Changelog →" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Right" Margin="0,2,0,0"
                        Command="{Binding OpenChangelogCommand}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                    <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="6" Padding="9,4" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource Caption}">
                            <Run Text="{Binding CurrentUserName, Mode=OneWay}" FontFamily="Segoe UI Semibold" />
                            <Run Text=" · " />
                            <Run Text="{Binding CurrentRoleLabel, Mode=OneWay}" />
                        </TextBlock>
                    </Border>
                    <Button Content="Odhlásiť" Style="{StaticResource GhostButton}" Margin="6,0,0,0"
                            Command="{Binding LogoutCommand}" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <ItemsControl ItemsSource="{Binding Chambers}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Width="470">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <views:ChamberGraphic Grid.Column="0" Width="150" Height="210"
                                                  VerticalAlignment="Top"
                                                  TitleText="{Binding KindLabel}" />

                            <StackPanel Grid.Column="1" Margin="14,2,0,0">
                                <TextBlock Text="{Binding Name}" FontFamily="Segoe UI Semibold" FontSize="16"
                                           TextWrapping="Wrap" />

                                <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="6"
                                        Padding="8,3" HorizontalAlignment="Left" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding KindLabel}" Style="{StaticResource Caption}" />
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Ellipse Width="11" Height="11" VerticalAlignment="Center"
                                             Fill="{Binding IsConnected, Converter={StaticResource BoolToBrush}}" />
                                    <TextBlock Text="{Binding ConnectionState}" Margin="8,0,0,0" Style="{StaticResource Caption}" />
                                    <Border Background="{StaticResource DangerBrush}" CornerRadius="6" Padding="7,2" Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsAlarm, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="ALARM" Foreground="White" FontFamily="Segoe UI Semibold" FontSize="11" />
                                    </Border>
                                </StackPanel>

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="IP adresa" Style="{StaticResource Label}" />
                                        <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Width="80">
                                        <TextBlock Text="Port" Style="{StaticResource Label}" />
                                        <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="Teplota" Style="{StaticResource Caption}" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontSize="26" FontFamily="Segoe UI Light"
                                                       Text="{Binding MeasuredTemperature, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0}" />
                                            <TextBlock Text="°C" VerticalAlignment="Bottom" Margin="4,0,0,4"
                                                       Foreground="{StaticResource MutedBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Visibility="{Binding SupportsHumidity, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="Vlhkosť" Style="{StaticResource Caption}" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontSize="26" FontFamily="Segoe UI Light"
                                                       Text="{Binding MeasuredHumidity, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0}" />
                                            <TextBlock Text="%" VerticalAlignment="Bottom" Margin="4,0,0,4"
                                                       Foreground="{StaticResource MutedBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Margin="0,10,0,0"
                                            Visibility="{Binding IsProfileRunning, Converter={StaticResource BoolToVisibility}}">
                                    <ProgressBar Value="{Binding ProfileProgress, Mode=OneWay}" Maximum="100" Height="6" />
                                    <TextBlock Text="{Binding ProfileStatus}" Style="{StaticResource Caption}"
                                               Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                    <Button Content="Pripojiť" Style="{StaticResource AccentButton}"
                                            Command="{Binding ConnectCommand}" />
                                    <Button Content="Odpojiť" Command="{Binding DisconnectCommand}" />
                                </StackPanel>

                                <Button Content="Nastaviť / ovládať →" Style="{StaticResource GhostButton}"
                                        Margin="0,10,0,0" HorizontalAlignment="Left"
                                        Command="{Binding DataContext.OpenChamberCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>

                            <Button Grid.ColumnSpan="2" Content="✕" Style="{StaticResource GhostButton}"
                                    HorizontalAlignment="Right" VerticalAlignment="Top" Padding="8,2" Margin="0"
                                    ToolTip="Odobrať komoru"
                                    Command="{Binding DataContext.RemoveChamberCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ===== Add chamber ===== -->
        <Border Style="{StaticResource Card}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Pridať komoru:" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,10,0" />
                <StackPanel Width="200" Margin="0,0,10,0">
                    <TextBlock Text="Názov" Style="{StaticResource Label}" />
                    <TextBox Text="{Binding NewChamberName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Width="170" Margin="0,0,10,0">
                    <TextBlock Text="Typ" Style="{StaticResource Label}" />
                    <ComboBox ItemsSource="{Binding ChamberKinds}" SelectedItem="{Binding NewChamberKind}" />
                </StackPanel>
                <StackPanel Width="150" Margin="0,0,10,0">
                    <TextBlock Text="IP adresa" Style="{StaticResource Label}" />
                    <TextBox Text="{Binding NewChamberHost, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <Button Content="Pridať" Style="{StaticResource AccentButton}" VerticalAlignment="Bottom"
                        Command="{Binding AddChamberCommand}" />
            </StackPanel>
        </Border>

        <!-- ===== E-mail notifications ===== -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <DockPanel LastChildFill="False">
                    <TextBlock Text="Notifikácie e-mailom" Style="{StaticResource Heading}" DockPanel.Dock="Left" />
                    <CheckBox Content="Zapnuté" IsChecked="{Binding Email.Enabled}" DockPanel.Dock="Right" />
                </DockPanel>

                <WrapPanel>
                    <StackPanel Style="{StaticResource MiniField}" Width="220">
                        <TextBlock Text="Adresát (komu)" Style="{StaticResource Label}" />
                        <TextBox Text="{Binding Email.Recipient, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource MiniField}">
                        <TextBlock Text="Spôsob" Style="{StaticResource Label}" />
                        <ComboBox ItemsSource="{Binding EmailMethods}" SelectedItem="{Binding Email.Method}" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource MiniField}" Width="220">
                        <TextBlock Text="Odosielateľ (from)" Style="{StaticResource Label}" />
                        <TextBox Text="{Binding Email.From, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </WrapPanel>

                <TextBlock Text="SMTP" Style="{StaticResource Caption}" Margin="0,6,0,4" />
                <WrapPanel>
                    <StackPanel Style="{StaticResource MiniField}" Width="200">
                        <TextBlock Text="Host" Style="{StaticResource Label}" />
                        <TextBox Text="{Binding Email.SmtpHost, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource MiniField}" Width="80">
                        <TextBlock Text="Port" Style="{StaticResource Label}" />
                        <TextBox Text="{Binding Email.SmtpPort, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource MiniField}" Width="70">
                        <TextBlock Text="SSL" Style="{StaticResource Label}" />
                        <CheckBox IsChecked="{Binding Email.SmtpUseSsl}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource MiniField}">
                        <TextBlock Text="Používateľ" Style="{StaticResource Label}" />
                        <TextBox Text="{Binding Email.SmtpUser, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource MiniField}">
                        <TextBlock Text="Heslo" Style="{StaticResource Label}" />
                        <TextBox Text="{Binding Email.SmtpPassword, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </WrapPanel>

                <TextBlock Text="HTTP API (napr. dbfood endpoint)" Style="{StaticResource Caption}" Margin="0,6,0,4" />
                <WrapPanel>
                    <StackPanel Style="{StaticResource MiniField}" Width="320">
                        <TextBlock Text="Endpoint URL" Style="{StaticResource Label}" />
                        <TextBox Text="{Binding Email.HttpEndpoint, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource MiniField}" Width="220">
                        <TextBlock Text="API kľúč (Bearer)" Style="{StaticResource Label}" />
                        <TextBox Text="{Binding Email.HttpApiKey, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </WrapPanel>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Uložiť nastavenia" Style="{StaticResource AccentButton}" Command="{Binding SaveEmailSettingsCommand}" />
                    <Button Content="Poslať test" Command="{Binding TestEmailCommand}" />
                    <TextBlock Text="{Binding EmailStatus}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="10,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
