<UserControl x:Class="VotschVc3.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:VotschVc3.App.Views">
    <UserControl.Resources>
        <!-- Grouped sub-panel inside a chamber card. -->
        <Style x:Key="Section" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <!-- Small pill badge (kind / state). -->
        <Style x:Key="Badge" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <!-- Vertical navigation button in the sidebar: full width, left-aligned label,
             transparent at rest, subtle surface fill + accent glyph bar on hover. -->
        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Margin" Value="0,0,0,3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="8" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- ===== Sidebar (left) + main content (right) ===== -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="236" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== Sidebar ===== -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="6,4,10,4" Padding="14,16">
            <DockPanel>
                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Riadenie laboratórnych zariadení" FontFamily="Segoe UI Semibold"
                               FontSize="16" TextWrapping="Wrap" TextTrimming="None" />
                    <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="6" Padding="8,3"
                            Margin="0,8,0,0" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding AppVersion}" Style="{StaticResource Caption}"
                                   ToolTip="Verzia aplikácie — pozri CHANGELOG.md" />
                    </Border>
                    <Separator Margin="0,14,0,10" Background="{StaticResource BorderBrush}" />
                </StackPanel>

                <!-- User + logout pinned to the bottom -->
                <StackPanel DockPanel.Dock="Bottom">
                    <Separator Margin="0,10,0,10" Background="{StaticResource BorderBrush}" />
                    <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="8" Padding="10,7">
                        <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap">
                            <Run Text="{Binding CurrentUserName, Mode=OneWay}" FontFamily="Segoe UI Semibold" />
                            <Run Text=" · " />
                            <Run Text="{Binding CurrentRoleLabel, Mode=OneWay}" />
                        </TextBlock>
                    </Border>
                    <Button Style="{StaticResource NavButton}" Margin="0,6,0,0" Command="{Binding LogoutCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Logout}" />
                            <TextBlock Text="Odhlásiť" Style="{StaticResource IconLabel}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Margin="0,6,0,0"
                            Foreground="{StaticResource DangerBrush}" Click="Exit_Click"
                            ToolTip="Úplne ukončí aplikáciu (s potvrdením). Krížik okno len skryje do oznamovacej oblasti.">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Power}" />
                            <TextBlock Text="Ukončiť aplikáciu" Style="{StaticResource IconLabel}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel VerticalAlignment="Top">
                    <Button Style="{StaticResource NavButton}" Command="{Binding OpenProfileLibraryCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Edit}" />
                            <TextBlock Text="Editor profilov" Style="{StaticResource IconLabel}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Command="{Binding OpenQuickProfileCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Bolt}" />
                            <TextBlock Text="Rýchly profil" Style="{StaticResource IconLabel}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Command="{Binding OpenThermometersCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Thermometer}" />
                            <TextBlock Text="Teplomery ASL F100" Style="{StaticResource IconLabel}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Command="{Binding OpenRecordingViewerCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Chart}" />
                            <TextBlock Text="Prehliadač záznamov" Style="{StaticResource IconLabel}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Command="{Binding OpenAuditCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.List}" />
                            <TextBlock Text="Audit trail" Style="{StaticResource IconLabel}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Command="{Binding OpenAppLogCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Document}" />
                            <TextBlock Text="App log" Style="{StaticResource IconLabel}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Command="{Binding OpenChangelogCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Book}" />
                            <TextBlock Text="Changelog" Style="{StaticResource IconLabel}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Command="{Binding OpenAdminCommand}"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource Icon.Gear}" />
                            <TextBlock Text="Administrácia" Style="{StaticResource IconLabel}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== Main content ===== -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
            <StackPanel Margin="0,4,0,0">

            <!-- ===== Timeline (Gantt) of every device: running profiles od–do,
                 manual runs fade out to ∞ (run until switched off). ===== -->
            <Border Style="{StaticResource Card}" Margin="7,7,7,0">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock Text="Časová os zariadení" Style="{StaticResource Heading}" DockPanel.Dock="Left" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Padding="8,2" FontSize="12"
                                VerticalAlignment="Center" Command="{Binding ToggleTimelineCommand}"
                                Content="{Binding TimelineToggleText}"
                                ToolTip="Skryť / zobraziť časovú os (šetrí miesto na obrazovke)." />
                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,12,0"
                                   Visibility="{Binding ShowTimeline, Converter={StaticResource BoolToVisibility}}">
                            <Run Text="■" Foreground="{StaticResource AccentBrush}" /><Run Text=" profil (od–do)    " />
                            <Run Text="■" Foreground="{StaticResource OkBrush}" /><Run Text=" manuálny beh · ∞ = kým sa nevypne" />
                        </TextBlock>
                    </DockPanel>
                    <views:FleetGanttView Chambers="{Binding VisibleChambers}" Margin="0,10,0,0"
                                          Visibility="{Binding ShowTimeline, Converter={StaticResource BoolToVisibility}}"
                                          ToolTip="Prejdi myšou po pruhu – ukáže profil a časy od–do." />
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding VisibleChambers}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Compact mode shrinks the whole card (graphic + text + spacing) via a
                             layout-scale, so more devices fit; toggled by the admin, reverts to the
                             original roomy layout when off. -->
                        <Border Width="500" Margin="7">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.CompactMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                            <Setter Property="LayoutTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="0.8" ScaleY="0.8" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>

                                <!-- ===== Top bar: reorder (admin) + primary "open device" action ===== -->
                                <DockPanel LastChildFill="False" Margin="0,0,0,12">
                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center"
                                                Visibility="{Binding DataContext.IsReorderAllowed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">
                                        <Button Content="◀" Style="{StaticResource GhostButton}" Padding="7,2"
                                                ToolTip="Posunúť doľava (admin)"
                                                Command="{Binding DataContext.MoveChamberUpCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="▶" Style="{StaticResource GhostButton}" Padding="7,2"
                                                ToolTip="Posunúť doprava (admin)"
                                                Command="{Binding DataContext.MoveChamberDownCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right" Content="⚙  Nastaviť / ovládať  →" Style="{StaticResource AccentButton}"
                                            Padding="16,9" FontSize="13"
                                            Command="{Binding DataContext.OpenChamberCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Otvoriť nastavenia a plné ovládanie zariadenia (pripojenie, profily, záznam, bezpečnosť…)." />
                                    <!-- Lock toggle: always enabled so a locked device can be unlocked. -->
                                    <Button DockPanel.Dock="Right" Margin="0,0,8,0" Padding="12,9" FontSize="13"
                                            Style="{StaticResource GhostButton}" Command="{Binding ToggleLockCommand}"
                                            ToolTip="Zamkne/odomkne zariadenie – v zamknutom stave sú všetky ovládacie tlačidlá neaktívne (ochrana pred neúmyselným stlačením počas behu).">
                                        <TextBlock>
                                            <Run Text="{Binding LockGlyph, Mode=OneWay}" /><Run Text=" " /><Run Text="{Binding LockButtonText, Mode=OneWay}" />
                                        </TextBlock>
                                    </Button>
                                </DockPanel>

                                <!-- Locked badge + inline unlock prompt (kept outside the disabled body). -->
                                <Border CornerRadius="8" Padding="10,7" Margin="0,0,0,10"
                                        Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1"
                                        Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                                                       Text="{Binding LockStateLabel}" FontFamily="Segoe UI Semibold" FontSize="13"
                                                       Foreground="{StaticResource DangerBrush}" />
                                            <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Style="{StaticResource Caption}"
                                                       Text="Ovládanie je uzamknuté" />
                                        </DockPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                    Visibility="{Binding IsUnlockPromptOpen, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="Heslo:" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <PasswordBox x:Name="UnlockPass" Width="150" Height="32" VerticalContentAlignment="Center"
                                                         Background="{StaticResource SurfaceAltBrush}" Padding="8,0"
                                                         KeyDown="UnlockPassword_KeyDown" />
                                            <Button Content="Odomknúť" Style="{StaticResource AccentButton}" Margin="8,0,0,0" Padding="12,4"
                                                    Tag="{Binding ElementName=UnlockPass}" Click="Unlock_Click" />
                                            <Button Content="Zrušiť" Style="{StaticResource GhostButton}" Margin="8,0,0,0" Padding="12,4"
                                                    Command="{Binding CancelUnlockCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ===== ① Header: graphic + name + badges + state ===== -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="128" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" VerticalAlignment="Top">
                                        <views:ChamberGraphic Width="128" Height="172"
                                                              IsRunning="{Binding IsActive}"
                                                              TitleText="{Binding KindLabel}"
                                                              Visibility="{Binding IsAsciiProtocol, Converter={StaticResource BoolToVisibility}}" />
                                        <views:PolEkoGraphic Width="128" Height="172"
                                                             IsRunning="{Binding IsActive}"
                                                             TemperatureText="{Binding MeasuredTemperature, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0}"
                                                             Visibility="{Binding IsPolEko, Converter={StaticResource BoolToVisibility}}" />
                                        <views:SikaThermalBathGraphic Width="128" Height="162"
                                                             IsRunning="{Binding IsActive}"
                                                             TemperatureText="{Binding MeasuredTemperature, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0}"
                                                             Visibility="{Binding IsSika, Converter={StaticResource BoolToVisibility}}" />
                                    </Grid>

                                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                        <!-- Read-only name (editing + removal live in device settings). -->
                                        <TextBlock Text="{Binding Name}" FontFamily="Segoe UI Semibold" FontSize="16"
                                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" VerticalAlignment="Top"
                                                   ToolTip="{Binding Name}" />

                                        <!-- Badges: kind, state, alarm -->
                                        <WrapPanel Margin="0,10,0,0">
                                            <Border Style="{StaticResource Badge}">
                                                <TextBlock Text="{Binding KindLabel}" Style="{StaticResource Caption}" />
                                            </Border>
                                            <Border Style="{StaticResource Badge}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                                                             Fill="{Binding IsActive, Converter={StaticResource BoolToBrush}}" />
                                                    <TextBlock Text="{Binding StateLabel}" Margin="6,0,0,0" FontFamily="Segoe UI Semibold" FontSize="12"
                                                               Foreground="{Binding IsActive, Converter={StaticResource BoolToBrush}}" />
                                                </StackPanel>
                                            </Border>
                                            <!-- Prominent control-mode badge: PROFIL vs MANUÁL. -->
                                            <Border Background="{StaticResource AccentBrush}" CornerRadius="7" Padding="9,4" VerticalAlignment="Center"
                                                    Visibility="{Binding HasControlMode, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding ControlModeBadge}" Foreground="White" FontFamily="Segoe UI Semibold" FontSize="12" />
                                            </Border>
                                            <Border Background="{StaticResource DangerBrush}" CornerRadius="7" Padding="9,4" VerticalAlignment="Center"
                                                    Visibility="{Binding IsAlarm, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="⚠ ALARM" Foreground="White" FontFamily="Segoe UI Semibold" FontSize="12" />
                                            </Border>
                                        </WrapPanel>

                                        <!-- Connection state + activity detail -->
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                                     Fill="{Binding IsConnected, Converter={StaticResource BoolToBrush}}" />
                                            <TextBlock Text="{Binding ConnectionState}" Margin="8,0,0,0" Style="{StaticResource Caption}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding ActivityLabel}" Style="{StaticResource Caption}"
                                                   Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                        <!-- Completion (day + time + countdown) right under the profile name. -->
                                        <TextBlock Text="{Binding ProfileCompletionText}" FontFamily="Segoe UI Semibold" FontSize="12.5"
                                                   Foreground="{StaticResource OkBrush}" Margin="0,4,0,0" TextWrapping="Wrap"
                                                   Visibility="{Binding HasProfileCompletion, Converter={StaticResource BoolToVisibility}}"
                                                   ToolTip="Predpokladané dokončenie profilu (deň, dátum a čas) a zostávajúci čas." />
                                        <!-- Slim progress bar right at the top of the device card while a profile runs. -->
                                        <Grid Margin="0,6,0,0"
                                              Visibility="{Binding IsProfileRunning, Converter={StaticResource BoolToVisibility}}">
                                            <ProgressBar Style="{StaticResource ProfileProgressBar}" Height="12"
                                                         Value="{Binding ProfileProgress, Mode=OneWay}" Maximum="100" />
                                            <TextBlock Text="{Binding ProfileProgress, StringFormat={}{0:0} %, Mode=OneWay}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       FontFamily="Segoe UI Semibold" FontSize="10" Foreground="White" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <!-- ===== ② Live values + range ===== -->
                                <Border Style="{StaticResource Section}" Margin="0,12,0,10">
                                    <StackPanel>
                                        <WrapPanel>
                                            <StackPanel Margin="0,0,22,0">
                                                <TextBlock Text="Teplota komory" Style="{StaticResource Caption}" />
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Style="{StaticResource MetricSmall}"
                                                               Text="{Binding MeasuredTemperature, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0}" />
                                                    <TextBlock Text="°C" VerticalAlignment="Bottom" Margin="3,0,0,4" Foreground="{StaticResource MutedBrush}" />
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,22,0">
                                                <TextBlock Text="Nastavená (setpoint)" Style="{StaticResource Caption}" />
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Style="{StaticResource MetricSub}" Foreground="{StaticResource WarnBrush}"
                                                               Text="{Binding MeasuredTemperatureSetpoint, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0}" />
                                                    <TextBlock Text="°C" VerticalAlignment="Bottom" Margin="3,0,0,3" Foreground="{StaticResource MutedBrush}" />
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Visibility="{Binding SupportsHumidity, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="Vlhkosť" Style="{StaticResource Caption}" />
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Style="{StaticResource MetricSmall}"
                                                               Text="{Binding MeasuredHumidity, Converter={StaticResource ValueOrDash}, ConverterParameter=0.0}" />
                                                    <TextBlock Text="%" VerticalAlignment="Bottom" Margin="3,0,0,4" Foreground="{StaticResource MutedBrush}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </WrapPanel>
                                        <TextBlock Style="{StaticResource Caption}" Margin="0,8,0,0" TextWrapping="Wrap">
                                            <Run Text="Rozsah: " Foreground="{StaticResource MutedBrush}" />
                                            <Run Text="{Binding RangeLabel, Mode=OneWay}" FontFamily="Segoe UI Semibold" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Control panels: disabled (greyed) while the device is locked, so a running
                                     profile / temperature can't be changed by an accidental press. Readouts above
                                     stay bright; the lock toggle lives in the top bar (always enabled). -->
                                <StackPanel IsEnabled="{Binding IsUnlocked}">

                                <!-- ===== ⑤ Quick control ===== -->
                                <Border Style="{StaticResource Section}">
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Text="Rýchle ovládanie" Style="{StaticResource Label}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                            <Button DockPanel.Dock="Right" Content="✎ Upraviť predvoľby" Style="{StaticResource GhostButton}"
                                                    Padding="6,1" FontSize="12" Command="{Binding ToggleEditPresetsCommand}"
                                                    Visibility="{Binding IsManageAllowed, Converter={StaticResource BoolToVisibility}}"
                                                    ToolTip="Admin: uprav teploty rýchleho ovládania pre toto zariadenie." />
                                        </DockPanel>

                                        <!-- Admin preset editor -->
                                        <StackPanel Margin="0,6,0,0" Visibility="{Binding IsEditingPresets, Converter={StaticResource BoolToVisibility}}">
                                            <TextBox Text="{Binding QuickPresetsText, UpdateSourceTrigger=LostFocus}"
                                                     ToolTip="Teploty oddelené čiarkou, napr. 60, 105, 150, 250" />
                                            <TextBlock Text="Teploty oddeľ čiarkou (1–8 hodnôt). Uloží sa po opustení poľa." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                                        </StackPanel>

                                        <!-- Preset temperature chips (primary one-tap actions) -->
                                        <ItemsControl ItemsSource="{Binding QuickPresets}" Margin="0,8,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource PresetChip}" Margin="0,0,7,7"
                                                            Content="{Binding}" ContentStringFormat="{}{0:0.#} °C"
                                                            ToolTip="Klikni = nastav túto teplotu a zapni komoru"
                                                            Command="{Binding DataContext.QuickSetTemperatureCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Custom temperature entry: set on the left, Stop separated on the right -->
                                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="10,9" Margin="0,2,0,0">
                                            <DockPanel LastChildFill="False">
                                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                    <TextBlock Text="Vlastná teplota" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                    <views:NumericStepper Width="92" VerticalAlignment="Center"
                                                                          Value="{Binding QuickTemperature, Mode=TwoWay}" Step="1"
                                                                          ToolTip="Teplota v °C – šípkami ▲▼ meníš po 1 °C." />
                                                    <TextBlock Text="°C" VerticalAlignment="Center" Margin="5,0,10,0" Foreground="{StaticResource MutedBrush}" />
                                                    <Button Content="Nastaviť" Style="{StaticResource AccentButton}" Margin="0" Height="36" MinWidth="96"
                                                            VerticalAlignment="Center" Command="{Binding QuickSetTemperatureCommand}" />
                                                </StackPanel>
                                                <Button Content="Stop" Style="{StaticResource DangerButton}" DockPanel.Dock="Right" Margin="0" Height="36" MinWidth="96"
                                                        VerticalAlignment="Center" Command="{Binding StopChamberCommand}"
                                                        ToolTip="Vypnúť komoru (zastaví reguláciu)." />
                                            </DockPanel>
                                        </Border>

                                        <!-- Action feedback banner: pops up after an action so the operator
                                             always sees what happened / what was switched on. Auto-clears. -->
                                        <Border Margin="0,8,0,0" CornerRadius="8" Padding="11,8"
                                                Background="{StaticResource SurfaceBrush}"
                                                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                                                Visibility="{Binding HasActionInfo, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{Binding ActionInfo}" Foreground="{StaticResource TextBrush}"
                                                       FontFamily="Segoe UI Semibold" TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ===== ④ Test profile: picker + play/pause/stop + preview ===== -->
                                <Border Style="{StaticResource Section}">
                                    <StackPanel>
                                        <TextBlock Text="Testovací profil" Style="{StaticResource Label}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0" VerticalAlignment="Center"
                                                      ItemsSource="{Binding History}" SelectedItem="{Binding SelectedHistoryProfile, Mode=TwoWay}"
                                                      ToolTip="Vyber uložený profil (aj z Rýchleho vytvárača) a spusti ho tlačidlom ▶.">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                                                <Button Style="{StaticResource IconActionButton}" Content="▶"
                                                        Foreground="{StaticResource OkBrush}" Command="{Binding StartSelectedProfileCommand}"
                                                        ToolTip="Spustiť vybraný profil" />
                                                <Button Style="{StaticResource IconActionButton}" Content="{Binding PauseResumeGlyph}"
                                                        Foreground="{StaticResource WarnBrush}" Command="{Binding PauseResumeProfileCommand}"
                                                        ToolTip="Pozastaviť / pokračovať" />
                                                <Button Style="{StaticResource IconActionButton}" Content="⏹"
                                                        Foreground="{StaticResource ErrorBrush}" Command="{Binding StopProfileCommand}"
                                                        Margin="0" ToolTip="Zastaviť profil" />
                                            </StackPanel>
                                        </Grid>

                                        <!-- Rad profilov: až 3 uložené profily spustené za sebou -->
                                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="10,8" Margin="0,10,0,0">
                                            <StackPanel>
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Style="{StaticResource Caption}">
                                                        <Run Text="Rad profilov " /><Run Text="{Binding ChainCountText, Mode=OneWay}" FontFamily="Segoe UI Semibold" />
                                                    </TextBlock>
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                        <Button Content="＋ Pridať do radu" Style="{StaticResource GhostButton}" Padding="9,3"
                                                                Command="{Binding AddToChainCommand}"
                                                                ToolTip="Pridá profil vybraný v zozname vyššie na koniec radu (max 3 profily za sebou)." />
                                                        <Button Content="▶ Spustiť rad" Style="{StaticResource AccentButton}" Margin="8,0,0,0" Padding="12,4"
                                                                Command="{Binding StartChainCommand}"
                                                                ToolTip="Spustí profily v rade za sebou, v poradí zľava doprava." />
                                                    </StackPanel>
                                                </DockPanel>

                                                <ItemsControl ItemsSource="{Binding ProfileChain}" Margin="0,8,0,0"
                                                              Visibility="{Binding HasChainedProfiles, Converter={StaticResource BoolToVisibility}}">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="7" Padding="10,5" Margin="0,0,7,7">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock VerticalAlignment="Center" TextTrimming="None">
                                                                        <Run Text="▸ " Foreground="{StaticResource OkBrush}" FontFamily="Segoe UI Semibold" /><Run Text="{Binding Name, Mode=OneWay}" />
                                                                    </TextBlock>
                                                                    <Button Content="✕" Style="{StaticResource GhostButton}" Padding="7,0" Margin="7,0,0,0"
                                                                            Foreground="{StaticResource DangerBrush}"
                                                                            Command="{Binding DataContext.RemoveFromChainCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            ToolTip="Odobrať z radu" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,0"
                                                           Text="{Binding ChainDurationText}"
                                                           Visibility="{Binding HasChainedProfiles, Converter={StaticResource BoolToVisibility}}" />
                                                <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,0"
                                                           Text="Vyber profil v zozname vyššie a pridaj ho do radu – profily pobežia za sebou (max 3)." />
                                            </StackPanel>
                                        </Border>

                                        <!-- Quick profile launch: curated one-click buttons; admin can pick which profiles show -->
                                        <StackPanel Margin="0,10,0,0" Visibility="{Binding HasProfiles, Converter={StaticResource BoolToVisibility}}">
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="Rýchle spustenie profilu" Style="{StaticResource Caption}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                                <Button DockPanel.Dock="Right" Content="✎ Upraviť" Style="{StaticResource GhostButton}"
                                                        Padding="6,1" FontSize="12" Command="{Binding ToggleEditQuickProfilesCommand}"
                                                        Visibility="{Binding IsManageAllowed, Converter={StaticResource BoolToVisibility}}"
                                                        ToolTip="Admin: vyber, ktoré profily sa zobrazia ako rýchle tlačidlá." />
                                                <Button DockPanel.Dock="Right" Content="✕ Zrušiť profil" Style="{StaticResource GhostButton}"
                                                        Padding="6,1" FontSize="12" Margin="0,0,8,0"
                                                        Foreground="{StaticResource DangerBrush}"
                                                        Command="{Binding CancelProfileCommand}"
                                                        ToolTip="Zastaví spustený profil (ak beží) a odoberie ho z karty, aby nezostal svietiť ako testovací profil." />
                                            </DockPanel>

                                            <!-- Admin editor: insert an existing profile / remove pinned ones -->
                                            <StackPanel Margin="0,6,0,8" Visibility="{Binding IsEditingQuickProfiles, Converter={StaticResource BoolToVisibility}}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox Grid.Column="0" ItemsSource="{Binding History}"
                                                              SelectedItem="{Binding ProfileToPin, Mode=TwoWay}" DisplayMemberPath="Name"
                                                              ToolTip="Vyber existujúci profil a pridaj ho tlačidlom Pridať." />
                                                    <Button Grid.Column="1" Content="Pridať" Margin="8,0,0,0" Style="{StaticResource AccentButton}"
                                                            Command="{Binding AddQuickProfileCommand}" />
                                                </Grid>
                                                <ItemsControl ItemsSource="{Binding PinnedProfileNames}" Margin="0,7,0,0"
                                                              Visibility="{Binding HasPinnedProfiles, Converter={StaticResource BoolToVisibility}}">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="7" Padding="10,5" Margin="0,0,7,7">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" TextTrimming="None" />
                                                                    <Button Content="✕" Style="{StaticResource GhostButton}" Padding="7,0" Margin="7,0,0,0"
                                                                            Foreground="{StaticResource DangerBrush}"
                                                                            Command="{Binding DataContext.RemoveQuickProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            ToolTip="Odobrať z rýchleho spustenia" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,3,0,0"
                                                           Text="Zobrazia sa iba tu pridané profily. Vyber v zozname vyššie tie, ktoré chceš mať ako rýchle spustenie." />
                                            </StackPanel>

                                            <!-- Empty-state hint when nothing is pinned yet. -->
                                            <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,5,0,0"
                                                       Visibility="{Binding HasNoQuickProfiles, Converter={StaticResource BoolToVisibility}}"
                                                       Text="Žiadne rýchle spustenie nie je nastavené. Admin ho pridá cez „✎ Upraviť“." />

                                            <!-- Launch buttons: full profile name, one click = load + start -->
                                            <ItemsControl ItemsSource="{Binding QuickProfiles}" Margin="0,5,0,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Style="{StaticResource PresetChip}" Margin="0,0,7,7"
                                                                Command="{Binding DataContext.QuickStartProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip="Klikni = spusti tento profil na komore">
                                                            <TextBlock TextWrapping="Wrap" TextTrimming="None" MaxWidth="430">
                                                                <Run Text="▶ " Foreground="{StaticResource OkBrush}" FontFamily="Segoe UI Semibold" /><Run Text="{Binding Name}" />
                                                            </TextBlock>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <!-- Odložený štart (pre toto zariadenie): keď je zapnuté, spustenie profilu sa naplánuje -->
                                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="10,8" Margin="0,10,0,0">
                                            <StackPanel>
                                                <CheckBox Content="Odložený štart" IsChecked="{Binding UseDelayedStart}"
                                                          ToolTip="Keď je zapnuté, spustenie profilu (▶ alebo rýchle tlačidlo) sa naplánuje na zadaný dátum a čas." />
                                                <!-- Keep the fields IsEnabled=true (dim via Opacity + block hit-testing when
                                                     the checkbox is off) so the NumericStepper's custom-templated TextBox always
                                                     renders its value; a control that starts inside a disabled subtree shows blank
                                                     text until focused, which is why the hour/minute used to look empty. -->
                                                <StackPanel Orientation="Horizontal" Margin="0,7,0,0">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Opacity" Value="1" />
                                                            <Setter Property="IsHitTestVisible" Value="True" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding UseDelayedStart}" Value="False">
                                                                    <Setter Property="Opacity" Value="0.55" />
                                                                    <Setter Property="IsHitTestVisible" Value="False" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text="Dátum" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                    <DatePicker Width="140" VerticalAlignment="Center"
                                                                SelectedDate="{Binding ScheduledStartDate, Mode=TwoWay}"
                                                                ToolTip="Vyber dátum z kalendára." />
                                                    <TextBlock Text="Čas" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="16,0,6,0" />
                                                    <views:NumericStepper Width="74" VerticalAlignment="Center"
                                                                          Value="{Binding ScheduledStartHour, Mode=TwoWay}" Step="1" Minimum="0" Maximum="23"
                                                                          ToolTip="Hodina (0–23)" />
                                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="4,0,4,0" Foreground="{StaticResource MutedBrush}" />
                                                    <views:NumericStepper Width="74" VerticalAlignment="Center"
                                                                          Value="{Binding ScheduledStartMinute, Mode=TwoWay}" Step="1" Minimum="0" Maximum="59"
                                                                          ToolTip="Minúta (0–59)" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding ProfileScheduleText}" Style="{StaticResource Caption}" Margin="0,6,0,0"
                                                           TextWrapping="Wrap"
                                                           Visibility="{Binding UseDelayedStart, Converter={StaticResource BoolToVisibility}}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="6,4" Margin="0,10,0,0"
                                                Visibility="{Binding HasProfilePreview, Converter={StaticResource BoolToVisibility}}">
                                            <StackPanel>
                                                <DockPanel LastChildFill="False" Margin="4,2,0,4">
                                                    <TextBlock Text="Graf profilu" Style="{StaticResource Caption}"
                                                               DockPanel.Dock="Left" VerticalAlignment="Center" />
                                                    <Button DockPanel.Dock="Right" Content="⛶ Zväčšiť" Style="{StaticResource GhostButton}"
                                                            Padding="9,3" FontSize="13" Click="MaximizeChart_Click"
                                                            ToolTip="Zväčšiť graf profilu na celú obrazovku (zavrieš ✕ alebo klávesom Esc)." />
                                                </DockPanel>
                                                <views:ChartView Height="210" Unit=" °C" Series="{Binding ProfilePreview}" EmptyText="Vyber profil"
                                                                 ToolTip="Prejdi myšou po krivke – ukáže teplotu a čas v danom bode." />
                                                <StackPanel Visibility="{Binding IsProfileRunning, Converter={StaticResource BoolToVisibility}}" Margin="0,8,0,0">
                                                    <Grid>
                                                        <ProgressBar Style="{StaticResource ProfileProgressBar}"
                                                                     Value="{Binding ProfileProgress, Mode=OneWay}" Maximum="100" />
                                                        <TextBlock Text="{Binding ProfileProgress, StringFormat={}{0:0} %, Mode=OneWay}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   FontFamily="Segoe UI Semibold" FontSize="11" Foreground="White" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding ProfileTimeRemaining}" FontFamily="Segoe UI Semibold" FontSize="16"
                                                               Foreground="{StaticResource TextBrush}" Margin="0,7,0,0" />
                                                    <TextBlock Text="{Binding ProfileScheduleText}" Style="{StaticResource Caption}"
                                                               Margin="0,2,0,0" FontFamily="Segoe UI Semibold" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding ProfileStatus}" Style="{StaticResource Caption}"
                                                               Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                </StackPanel>
                                <!-- Pripojenie (IP/port), referenčný teplomer, odobratie a premenovanie
                                     zariadenia sú v obrazovke „Nastaviť / ovládať →" (hore na karte). -->
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
